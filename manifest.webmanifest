<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="#756e5f">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="manifest.webmanifest">
  <link rel="icon" type="image/png" href="app-icon.png">
  <link rel="apple-touch-icon" href="app-icon.png">
  <meta property="og:title" content="一起點餐">
  <meta property="og:description" content="輕鬆發起與加入點餐訂單">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://byjhen.github.io/drink-order-app/">
  <meta property="og:image" content="https://byjhen.github.io/drink-order-app/app-icon.png">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1280">
  <meta property="og:image:height" content="1280">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:image" content="https://byjhen.github.io/drink-order-app/app-icon.png">
  <title>一起點餐</title>
  <style>
    :root{--p:#756e5f;--pd:#514c42;--ink:#34332f;--muted:#77746b;--bg:#f5f3ed;--card:#fffefa;--line:#e5e1d6;--ok:#4f755a;--warn:#9a6b31;--danger:#a44c45}
    *{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--ink);font:15px system-ui,"Noto Sans TC",sans-serif}button,input,select,textarea{font:inherit}button{cursor:pointer;border:0}.app{max-width:820px;margin:auto;min-height:100vh;padding-bottom:76px}.top{background:linear-gradient(125deg,#898170,#687166);color:#fff;padding:24px 20px 18px;position:sticky;top:0;z-index:5;box-shadow:0 2px 12px #3332}.brand{font-size:23px;font-weight:900;letter-spacing:.08em}.sub{font-size:14px;opacity:.9;margin-top:4px}.page{padding:18px}.tabs{display:flex;gap:8px;overflow:auto;padding:12px 18px 0}.tab{white-space:nowrap;background:#e8e4da;color:#625e53;border-radius:99px;padding:8px 14px;font-weight:800}.tab.on{background:var(--p);color:#fff}.card{background:var(--card);border-radius:14px;padding:16px;margin:0 0 14px;box-shadow:0 3px 13px #554e360b;border:1px solid #ebe7dc}.store-head,.between{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}.store-head h2{font-size:19px;margin:4px 0 6px}.badge{display:inline-block;background:#ece8dd;color:#625d4f;border-radius:5px;padding:3px 7px;font-size:12px;font-weight:800}.deadline{font-size:13px;color:var(--muted);margin:8px 0}.deadline.open{color:var(--ok);font-weight:800}.btn{background:var(--p);color:#fff;border-radius:8px;padding:10px 14px;font-weight:800}.btn:hover{background:var(--pd)}.btn.light{background:#ebe8df;color:#5e5a50}.btn.dark{background:#44453f}.btn.danger{background:var(--danger)}.btn.full{width:100%}.btn.smallbtn{padding:7px 10px;font-size:13px}.empty{text-align:center;padding:42px 20px;color:var(--muted)}.empty b{display:block;color:var(--ink);font-size:17px;margin-bottom:7px}.menu-item{display:flex;gap:12px;align-items:center;padding:13px 0;border-bottom:1px solid var(--line)}.menu-item:last-child{border:0}.food-icon{width:44px;height:44px;border-radius:12px;background:#ece9de;display:grid;place-items:center;font-size:22px;flex:0 0 auto}.grow{flex:1;min-width:0}.name{font-weight:900}.price,.money{color:#6e654f;font-weight:900;margin-top:4px}.small{font-size:13px;color:var(--muted)}.qty{display:flex;align-items:center;gap:10px}.qty button{width:30px;height:30px;border-radius:50%;background:#e6e2d6;color:#5f5a4e;font-size:20px;line-height:1}.qty button:disabled{opacity:.35}.bottom{position:fixed;bottom:0;left:0;right:0;background:var(--card);border-top:1px solid var(--line);display:flex;justify-content:center;z-index:4}.bottomin{width:min(820px,100%);display:flex}.nav{flex:1;padding:10px 4px;color:#85827a;background:var(--card);font-size:12px}.nav.on{color:#5f594b;font-weight:900}.nav span{display:block;font-size:20px}.form label{display:block;font-size:13px;font-weight:800;margin:14px 0 6px}.form input,.form select,.form textarea,.menu-item select,.filters input,.filters select{width:100%;padding:10px;border:1px solid #dcd8cc;border-radius:8px;background:#fffefa}.form textarea{min-height:110px;resize:vertical}.row{display:flex;gap:10px}.row>*{flex:1;min-width:0}.total{display:flex;justify-content:space-between;background:#efede5;padding:13px;border-radius:8px;margin:16px 0;font-weight:900}.hidden{display:none!important}.adminbar{background:#44453f;color:#fff;padding:12px 18px;display:flex;align-items:center;justify-content:space-between}.adminbar button{background:transparent;color:#fff;font-weight:800}.section-title{font-size:20px;margin:8px 0 14px}.pill{padding:5px 9px;border-radius:99px;font-size:12px;font-weight:800;background:#eef0f1}.paid{background:#dfeee2;color:#426c50}.unpaid{background:#f7e8cd;color:#8d632b}.order{border-bottom:1px solid var(--line);padding:11px 0}.order:last-child{border:0}.modal{position:fixed;inset:0;background:#24241f77;display:grid;place-items:center;padding:20px;z-index:20}.modalbox{background:var(--card);border-radius:15px;padding:22px;width:min(460px,100%);max-height:92vh;overflow:auto;box-shadow:0 12px 30px #0004}.modalbox h2{margin:0 0 10px}.notice{text-align:center}.notice .tick{font-size:44px}.adminlist{display:flex;gap:8px;flex-wrap:wrap}.summary{font-size:13px;background:#f3f1ea;border-radius:8px;padding:11px;margin:9px 0}.divider{border:0;border-top:1px solid var(--line);margin:18px 0}.hint{font-size:12px;color:var(--muted);margin-top:6px;line-height:1.6}.filters{display:grid;grid-template-columns:1fr 160px;gap:10px;margin-bottom:14px}.wanted{position:sticky;top:91px;z-index:3;background:#363832;color:white;border-radius:11px;padding:12px 15px;margin-bottom:14px;font-weight:900;box-shadow:0 4px 14px #0002}.wanted span{color:#ffdea2}.group-title{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:8px}.group-title h3{margin:0;font-size:17px}.group-meta{font-size:12px;color:var(--muted);margin:3px 0}.item-line{display:flex;justify-content:space-between;gap:12px;margin-top:4px}.item-line span:first-child{min-width:0}.order-grid{display:grid;grid-template-columns:minmax(110px,1fr) 2fr auto;gap:10px;align-items:start}.store-section{border-left:4px solid #aca590}.store-section>h3{margin:0 0 4px}.date-heading{font-size:16px;margin:20px 0 9px}.filehint{font-size:12px;color:var(--muted);margin-top:5px}@media(max-width:560px){.page{padding:14px}.row{display:block}.filters{grid-template-columns:1fr}.order-grid{grid-template-columns:1fr auto}.order-grid .details{grid-column:1/-1}.wanted{top:89px}}
  </style>
  <style>.footer{padding:0;height:0}.jj-signature{position:fixed;right:11px;bottom:67px;font-size:7px;font-family:Inter,system-ui,sans-serif;color:#ded9d1;letter-spacing:1.4px;font-weight:300;opacity:0;pointer-events:none;user-select:none;transition:opacity 1.2s ease;z-index:3}.jj-signature.show{opacity:.08}.legal{white-space:pre-line;line-height:1.75;text-align:left}.form label:has(+ #smethod),#smethod{display:none!important}#menuFormatHint + .hint{display:none}.pick-item{cursor:pointer;border-radius:10px;padding:11px 8px;margin:0 -8px}.pick-item:hover{background:#f3f1ea}.pick-item .pick-hint{margin-top:5px;color:var(--p);font-size:12px;font-weight:800}.modalbox.notice{background:#fff;border-radius:20px;padding:32px 24px 24px;box-shadow:0 12px 40px rgba(0,0,0,.12)}.success-icon{width:56px;height:56px;border:1.5px solid #D1D5DB;border-radius:50%;display:grid;place-items:center;margin:0 auto 20px;color:#4B5563;font-size:30px;font-weight:600;line-height:1}.notice h2{font-size:21px;margin:0 0 10px;font-weight:700}.notice p{font-size:16px;color:#6B7280;margin:0 0 24px}.success-actions{display:grid;gap:12px}.btn.outline{background:#fff;color:var(--p);border:1px solid #cfcac0}.btn.outline:hover{background:#f5f3ed}</style>
<style>.history-item{display:flex;align-items:center;gap:8px;margin-top:5px}.history-item .history-text{flex:1;min-width:0}.history-item .history-price{white-space:nowrap;font-weight:800;color:#6e654f}.history-item .history-qty{white-space:nowrap;font-weight:800}.history-item .pill{white-space:nowrap}button[onclick="startAllOrder()"]{display:none}</style>

<style>
.build-methods{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:8px 0 4px}
.build-method{border:1px solid var(--line);border-radius:12px;padding:13px;background:#fff;cursor:pointer}
.build-method.on{border-color:var(--p);box-shadow:0 0 0 2px #756e5f22;background:#faf8f2}
.build-method b{display:block;margin-bottom:4px}
.required{color:var(--danger)}
.quick-row{border:1px solid var(--line);border-radius:10px;padding:12px;margin:10px 0;background:#fff}
.quick-grid{display:grid;grid-template-columns:1.4fr 1fr 90px 110px auto;gap:8px;align-items:end}
.quick-grid label{margin:0 0 5px}
.quick-remove{height:41px}
@media(max-width:650px){.build-methods{grid-template-columns:1fr}.quick-grid{grid-template-columns:1fr 1fr}.quick-grid .wide{grid-column:1/-1}.quick-remove{width:100%}}
</style>
<style>
  /* Layout refinements: keep navigation available while reading long menus. */
  .menu-tabs-sticky{
    position:sticky;
    top:76px;
    z-index:4;
    margin:0 -16px 10px;
    padding:10px 16px !important;
    background:rgba(249,247,241,.94);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(220,216,204,.85);
  }
  #tabs.admin-tabs-sticky{
    position:sticky;
    top:76px;
    z-index:4;
    padding:12px 18px 10px;
    background:rgba(249,247,241,.94);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    border-bottom:1px solid rgba(220,216,204,.85);
  }
  .wanted{
    background:rgba(255,255,255,.52);
    color:#494c45;
    border:1px solid rgba(255,255,255,.7);
    box-shadow:0 8px 22px rgba(54,56,50,.16);
    backdrop-filter:blur(14px);
    -webkit-backdrop-filter:blur(14px);
  }
  .wanted span{color:#625d4f}
  .wanted{white-space:nowrap;overflow:hidden;font-size:clamp(11px,3.7vw,15px)}
  .group-message{margin-top:10px;padding:9px 11px;border-radius:8px;background:#fbf3e3;color:#625d4f;font-size:12px;font-weight:800;line-height:1.45;white-space:pre-line}
  @media(max-width:560px){.menu-tabs-sticky,#tabs.admin-tabs-sticky{top:76px}}
</style>
</head>
<body>
<main class="app">
  <header class="top"><div class="brand">一起點餐</div><div class="sub" id="headline">今天想吃什麼？</div></header>
  <div id="adminBar" class="adminbar hidden"><b>管理模式</b><button onclick="logout()">登出</button></div>
  <div id="tabs" class="tabs hidden"></div>
  <section id="view" class="page"></section>
  <footer class="footer"><div class="jj-signature" aria-hidden="true">© 2026 JJ</div></footer>
  <nav class="bottom"><div class="bottomin">
    <button class="nav on" onclick="go('home')"><span>🍽️</span>開放點餐</button>
    <button class="nav" onclick="go('history')"><span>🧾</span>歷史訂單</button>
    <button class="nav" onclick="openAdmin()"><span>⚙️</span>管理</button>
  </div></nav>
</main>
<div id="modal"></div>
<script>
const KEY='together-order-v1';
const APP_VERSION='v1.0.0', COPYRIGHT='Copyright © 2026 JJ. All rights reserved.';
const SUPABASE_URL='https://duwinxwcovmplqqkizrk.supabase.co';
const SUPABASE_KEY='sb_publishable_fRwQthTt4FyTSK3AbVu3nQ_Ou_NWItt';
const EMPTY={password:'20260713',stores:[],groups:[],orders:[]};
let data=normalize(JSON.parse(localStorage.getItem(KEY)||'null')||structuredClone(EMPTY));
let state={page:'home',group:null,cart:{},buyer:'',focusItem:null,selectedItem:null,menuSection:null,adminTab:0,orderTab:0,orderDate:localDate(new Date())},syncTimer=null;
const $=s=>document.querySelector(s);
const now=()=>new Date();
const headers={'apikey':SUPABASE_KEY,'Authorization':'Bearer '+SUPABASE_KEY,'Content-Type':'application/json'};
function normalize(raw){raw=raw&&typeof raw==='object'?raw:{};return {password:raw.password||EMPTY.password,stores:Array.isArray(raw.stores)?raw.stores:[],groups:Array.isArray(raw.groups)?raw.groups.map(g=>({...g,creator:g.creator||'',payee:g.payee||''})):[],orders:Array.isArray(raw.orders)?raw.orders:[]}}
function esc(s=''){return String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
function fmt(d,withTime=true){if(!d)return '—';return new Intl.DateTimeFormat('zh-TW',{timeZone:'Asia/Taipei',year:'numeric',month:'2-digit',day:'2-digit',...(withTime?{hour:'2-digit',minute:'2-digit',hour12:false}:{})}).format(new Date(d))}
function localDate(d){return new Intl.DateTimeFormat('en-CA',{timeZone:'Asia/Taipei',year:'numeric',month:'2-digit',day:'2-digit'}).format(new Date(d))}
function store(id){return data.stores.find(x=>x.id===id)}function group(id){return data.groups.find(x=>x.id===id)}
function isOpen(g){return !!g&&!g.manualClosed&&new Date(g.deadline)>now()}
function mapUrl(address){return 'https://www.google.com/maps/search/?api=1&query='+encodeURIComponent(address||'')}
function mapHtml(address){return ''}
function optionGroups(item){return Array.isArray(item.optionGroups)?item.optionGroups.filter(g=>g?.name&&Array.isArray(g.values)&&g.values.length):[]}
function cartEntry(item,i){const current=state.cart[i]||{};const defaults=Object.fromEntries(optionGroups(item).map(g=>[g.name,g.values[0]]));return {...current,q:current.q||0,variant:current.variant||0,options:{...defaults,...(current.options||{})}}}
function selectedPrice(item,cart){let price=Number(item.price)||0;optionGroups(item).forEach(g=>{const value=cart.options[g.name],n=Number(g.adjustments?.[value]||0);if(g.pricing)price=n;else price+=n});return price}
function variants(item){const groups=optionGroups(item);if(groups.length){const pricing=groups.find(g=>g.pricing),price=pricing?Number(pricing.adjustments?.[pricing.values[0]])||0:Number(item.price)||0;return[{spec:groups.map(g=>`${g.name}（${g.values.join('、')}）`).join('／'),price}]}if(Array.isArray(item.variants)&&item.variants.length)return item.variants.map(v=>({spec:v.spec||'單一規格',price:Number(v.price)||0}));let specs=String(item.specs||'單一規格').split(/[、,，|｜]/).map(x=>x.trim()).filter(Boolean);return specs.map(spec=>({spec,price:Number(item.price)||0}))}
function save(){data=normalize(data);localStorage.setItem(KEY,JSON.stringify(data));clearTimeout(syncTimer);syncTimer=setTimeout(pushShared,350)}
async function pushShared(){try{const r=await fetch(SUPABASE_URL+'/rest/v1/together_order_state?id=eq.shared',{method:'PATCH',headers:{...headers,'Prefer':'return=minimal'},body:JSON.stringify({payload:data,updated_at:new Date().toISOString()})});if(!r.ok)throw new Error(await r.text())}catch(e){console.warn('雲端同步暫時失敗，資料已保存在本機。',e)}}
async function loadSharedState(){try{const r=await fetch(SUPABASE_URL+'/rest/v1/together_order_state?id=eq.shared&select=payload',{headers});if(!r.ok)throw new Error(await r.text());const rows=await r.json();if(rows[0]?.payload){data=normalize(rows[0].payload);localStorage.setItem(KEY,JSON.stringify(data))}else{await fetch(SUPABASE_URL+'/rest/v1/together_order_state',{method:'POST',headers:{...headers,'Prefer':'return=minimal'},body:JSON.stringify({id:'shared',payload:data})})}}catch(e){console.warn('目前使用本機資料。',e)}render()}
function go(page){state.page=page;if(page==='home')state.group=null;render()}
function render(){const p=state.page;$('#tabs').classList.add('hidden');$('#adminBar').classList.add('hidden');document.querySelectorAll('.nav').forEach((x,i)=>x.classList.toggle('on',(p==='home'&&i===0)||(p==='history'&&i===1)||(p==='admin'&&i===2)));if(p==='home')home();else if(p==='menu')menu();else if(p==='order')orderForm();else if(p==='history')history();else admin()}
function home(){const active=data.groups.filter(isOpen).sort((a,b)=>new Date(a.deadline)-new Date(b.deadline));$('#headline').textContent=active.length?`目前有 ${active.length} 個團購進行中`:'目前沒有開放中的團購';$('#view').innerHTML=active.length?active.map(g=>{const s=store(g.storeId)||{};return `<article class="card"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name||'已刪除店家')}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><b class="deadline open">開放中</b></div><div class="deadline">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div><button class="btn full" onclick="state.group='${g.id}';go('menu')">查看菜單／點餐</button></article>`}).join(''):`<div class="empty"><b>現在沒有開放中的團購</b>管理者開團後，就可以在這裡開始點餐。</div>`}
function menu(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}$('#headline').textContent=s.name;$('#view').innerHTML=`<button class="btn light" onclick="go('home')">返回團購</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<hr class="divider">${s.items.map(item=>`<div class="menu-item"><div class="food-icon">${s.category==='飲料'?'🧋':'🍱'}</div><div class="grow"><div class="name">${esc(item.name)}</div><div class="small">${variants(item).map(v=>`${esc(v.spec)} NT$ ${v.price.toLocaleString()}`).join('・')}</div></div></div>`).join('')||'<p class="small">這間店尚未建立餐點。</p>'}<button class="btn full" style="margin-top:14px" onclick="state.cart={};state.buyer='';go('order')">開始點餐</button></div>`}
function orderForm(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}const lines=s.items.map((item,i)=>{const vs=variants(item),groups=optionGroups(item),c=cartEntry(item,i),price=groups.length?Number(item.price)||0:(vs[c.variant]?.price||0);const controls=groups.length?groups.map(gr=>`<label class="small" style="margin-top:8px">${esc(gr.name)}</label><select aria-label="${esc(item.name)}${esc(gr.name)}" onchange="setOption(${i},'${esc(gr.name)}',this.value)">${gr.values.map(v=>`<option ${c.options[gr.name]===v?'selected':''}>${esc(v)}</option>`).join('')}</select>`).join(''):`<label class="small" style="margin-top:8px">規格</label><select aria-label="${esc(item.name)}規格" onchange="setVariant(${i},this.value)">${vs.map((v,j)=>`<option value="${j}" ${Number(c.variant)===j?'selected':''}>${esc(v.spec)}</option>`).join('')}</select>`;return `<div class="menu-item"><div class="grow"><div class="small">品項</div><div class="name">${esc(item.name)}</div>${controls}<div class="small" style="margin-top:8px">價錢</div><div class="price">NT$ ${price.toLocaleString()}</div></div><div class="qty"><button ${!c.q?'disabled':''} onclick="changeQty(${i},-1)">−</button><b>${c.q||0}</b><button onclick="changeQty(${i},1)">＋</button></div></div>`}).join('');$('#headline').textContent='填寫訂單';$('#view').innerHTML=`<button class="btn light" onclick="go('menu')">返回菜單</button><div class="card form" style="margin-top:14px"><label>訂購人 <em style="color:var(--danger)">*</em></label><input id="buyer" maxlength="30" placeholder="請輸入姓名" value="${esc(state.buyer||'')}" oninput="state.buyer=this.value"><label>品項</label>${lines}<div class="total"><span>訂單總金額</span><span id="total">NT$ 0</span></div><button class="btn full" onclick="submitOrder()">送出訂單</button></div>`;updateTotal()}
function setVariant(i,v){const c=state.cart[i]||{q:0,options:{}};c.variant=Number(v);state.cart[i]=c;orderForm()}
function setOption(i,name,value){const c=state.cart[i]||{q:0,variant:0,options:{}};c.options={...(c.options||{}),[name]:value};state.cart[i]=c;orderForm()}
function changeQty(i,n){const s=store(group(state.group).storeId),c=cartEntry(s.items[i],i);c.q=Math.max(0,(c.q||0)+n);state.cart[i]=c;orderForm()}
function updateTotal(){const s=store(group(state.group).storeId);const total=s.items.reduce((sum,item,i)=>{const c=cartEntry(item,i),price=optionGroups(item).length?selectedPrice(item,c):(variants(item)[c.variant]?.price||0);return sum+c.q*price},0);if($('#total'))$('#total').textContent='NT$ '+total.toLocaleString()}
async function submitOrder(){const g=group(state.group);if(!isOpen(g)){alert('這個團購已經結束');return go('home')}const buyer=$('#buyer').value.trim(),s=store(g.storeId);const items=s.items.flatMap((item,i)=>{const c=cartEntry(item,i);if(!c.q)return[];const groups=optionGroups(item),v=variants(item)[c.variant];return[{name:item.name,spec:groups.length?groups.map(gr=>`${gr.name}:${c.options[gr.name]}`).join('、'):v.spec,qty:c.q,price:groups.length?selectedPrice(item,c):v.price}]});if(!buyer)return alert('請輸入訂購人');if(!items.length)return alert('請至少選擇一份餐點');const newOrder={id:crypto.randomUUID(),groupId:g.id,buyer,items,total:items.reduce((a,x)=>a+x.qty*x.price,0),paid:false,createdAt:new Date().toISOString()};try{const r=await fetch(SUPABASE_URL+'/rest/v1/rpc/append_together_order',{method:'POST',headers,body:JSON.stringify({new_order:newOrder})});if(!r.ok)throw new Error(await r.text());data=normalize(await r.json());localStorage.setItem(KEY,JSON.stringify(data))}catch(e){data.orders.push(newOrder);save()}state.cart={};showOrderSuccess()}
function wantedHtml(orders){const people=[...new Set(orders.filter(o=>!o.paid).map(o=>o.buyer).filter(Boolean))].sort(()=>Math.random()-.5).slice(0,2);return `<div class="wanted"><b>🗿通緝犯</b>${people.length?' '+people.map(esc).join('、'):' 從缺'}</div>`}
function orderLines(o){return o.items.map(x=>`<div class="item-line"><span>${esc(x.name)}／${esc(x.spec||'單一規格')}</span><b>× ${Number(x.qty)||0}</b></div>`).join('')}
function historySpec(spec){return String(spec||'單一規格').replace(/(?:^|[、，]\s*)[^、，:：]+[：:]/g,' ').replace(/[、，]/g,' ').replace(/\s+/g,' ').trim()||'單一規格'}
function historyLines(o){return o.items.map(x=>{const price=Number(x.price||0),qty=Number(x.qty)||0;return `<div class="history-item"><span class="history-text">${esc(x.name)}／${esc(historySpec(x.spec))}</span><span class="history-price">$${price.toLocaleString()}</span><span class="history-qty">× ${qty}</span><span class="history-price">總額 $${(price*qty).toLocaleString()}</span><span class="pill ${o.paid?'paid':'unpaid'}">${o.paid?'已付款':'未付款'}</span></div>`}).join('')}
function historyGroup(g){const s=store(g.storeId)||{},orders=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));return `<article class="card"><div class="group-title"><div><h3>${esc(s.name||'已刪除店家')}</h3><div class="group-meta">開團者：${esc(g.creator||'未填寫')}・${isOpen(g)?'收單 '+fmt(g.deadline):'已於 '+fmt(g.deadline)+' 結束'}</div></div><span class="pill ${isOpen(g)?'paid':'unpaid'}">${isOpen(g)?'本次團購':'過往團購'}</span></div>${orders.map(o=>`<div class="order"><b>${esc(o.buyer)}</b>${historyLines(o)}<div class="small">訂購時間：${fmt(o.createdAt)}</div></div>`).join('')||'<div class="empty">這次團購還沒有訂單</div>'}</article>`}
function history(){const active=data.groups.filter(isOpen).sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));const ended=data.groups.filter(g=>!isOpen(g)).sort((a,b)=>new Date(b.deadline)-new Date(a.deadline)).slice(0,2);const shown=[...active,...ended];const shownOrders=data.orders.filter(o=>shown.some(g=>g.id===o.groupId));$('#headline').textContent='本次與最近兩次團購';$('#view').innerHTML=wantedHtml(shownOrders)+(shown.length?shown.map(historyGroup).join(''):`<div class="empty"><b>還沒有歷史訂單</b>完成點餐後，訂單會顯示在這裡。</div>`)}
function openAdmin(){$('#modal').innerHTML=`<div class="modal"><div class="modalbox form"><h2>管理登入</h2><label>管理密碼</label><input id="adminPassword" type="password" autocomplete="current-password" placeholder="請輸入管理密碼" onkeydown="if(event.key==='Enter')doAdminLogin()"><div class="row" style="margin-top:16px"><button class="btn light" onclick="closeModal()">取消</button><button class="btn" onclick="doAdminLogin()">登入</button></div></div></div>`;setTimeout(()=>$('#adminPassword')?.focus(),0)}
function doAdminLogin(){if($('#adminPassword').value!==data.password)return alert('密碼錯誤');closeModal();state.page='admin';render()}
function logout(){state.page='home';render()}
function admin(){$('#headline').textContent='團購後台管理';$('#adminBar').classList.remove('hidden');$('#tabs').classList.remove('hidden');const names=['開團管理','店家與菜單','訂單管理','設定'];$('#tabs').innerHTML=names.map((x,i)=>`<button class="tab ${i===state.adminTab?'on':''}" onclick="state.adminTab=${i};admin()">${x}</button>`).join('');$('#view').innerHTML=[adminGroups,adminStores,adminOrders,adminSettings][state.adminTab]();if(state.adminTab===1)setupMenuFormatHint()}
function setupMenuFormatHint(){const area=$('#sitems');if(!area||$('#menuFormatHint'))return;const label=[...$('#view').querySelectorAll('label')].find(x=>x.textContent.includes('餐點內容'));if(label)label.textContent='餐點內容（區塊格式）';area.insertAdjacentHTML('afterend',`<div id="menuFormatHint" class="summary"><b>區塊式菜單格式</b><br><code>【飽胃主食】</code><br><code>品項：傳統滷肉飯</code><br><code>規格：</code><br><code>- [分量與價格]：小碗=35, 大碗=50, 巨無霸=70</code><br><code>- [加料]：不加=+0, 加滷蛋=+15</code><br><span class="small">名稱含「價格」的規格群組會決定基礎價；其他「=+金額」選項會加在總價上。規格群組可自行新增或省略。</span></div>`)}
function adminGroups(){const rows=[...data.groups].sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));return `<h2 class="section-title">開團管理</h2><div class="card form"><label>選擇店家</label><select id="gstore">${data.stores.map(s=>`<option value="${s.id}">${esc(s.name)}（${esc(s.category||'未分類')}）</option>`).join('')||'<option value="">請先建立店家</option>'}</select><label>開團者</label><input id="gcreator" maxlength="30" placeholder="請輸入開團者姓名"><label>付款者</label><input id="gpayee" maxlength="30" placeholder="請輸入收款人姓名"><label>收單時間</label><input id="deadline" type="datetime-local"><button class="btn full" style="margin-top:14px" onclick="createGroup()">建立新團購</button></div><div class="card"><b>開團紀錄</b>${rows.map(g=>`<div class="order"><b>${esc(store(g.storeId)?.name||'已刪除店家')}</b><span class="pill ${isOpen(g)?'paid':'unpaid'}" style="float:right">${isOpen(g)?'開放中':'已結束'}</span><div class="small">開團者：${esc(g.creator||'未填寫')}・付款者：${esc(g.payee||'未填寫')}・收單 ${fmt(g.deadline)}</div><div class="adminlist" style="margin-top:8px"><button class="btn light smallbtn" onclick="editGroup('${g.id}')">編輯</button>${isOpen(g)?`<button class="btn dark smallbtn" onclick="manualClose('${g.id}')">立即收單</button>`:''}<button class="btn danger smallbtn" onclick="deleteGroup('${g.id}')">刪除開團</button></div></div>`).join('')||'<p class="small">尚無開團紀錄</p>'}</div>`}
function createGroup(){if(!data.stores.length)return alert('請先建立店家');const d=$('#deadline').value,creator=$('#gcreator').value.trim(),payee=$('#gpayee').value.trim();if(!creator)return alert('請輸入開團者');if(!payee)return alert('請輸入付款者');if(!d)return alert('請選擇收單時間');const iso=new Date(d).toISOString();if(new Date(iso)<=now())return alert('收單時間必須晚於現在');data.groups.push({id:crypto.randomUUID(),storeId:$('#gstore').value,creator,payee,deadline:iso,createdAt:new Date().toISOString(),manualClosed:false});save();admin()}
function editGroup(id){const g=group(id);const d=new Date(g.deadline),v=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}T${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;$('#modal').innerHTML=`<div class="modal"><div class="modalbox form"><h2>編輯團購</h2><label>開團者</label><input id="editCreator" value="${esc(g.creator||'')}"><label>付款者</label><input id="editPayee" value="${esc(g.payee||'')}"><label>收單時間</label><input id="editDeadline" type="datetime-local" value="${v}"><div class="row" style="margin-top:16px"><button class="btn light" onclick="closeModal()">取消</button><button class="btn" onclick="saveGroupEdit('${id}')">儲存並重新開放</button></div></div></div>`}
function saveGroupEdit(id){const g=group(id),creator=$('#editCreator').value.trim(),payee=$('#editPayee').value.trim(),d=$('#editDeadline').value;if(!creator||!payee||!d)return alert('請完整填寫開團者、付款者與收單時間');const iso=new Date(d).toISOString();if(new Date(iso)<=now())return alert('收單時間必須晚於現在');g.creator=creator;g.payee=payee;g.deadline=iso;g.manualClosed=false;save();closeModal();admin()}
function manualClose(id){if(!confirm('確定要立即結束這次團購嗎？'))return;group(id).manualClosed=true;save();admin()}
function deleteGroup(id){const related=data.orders.filter(o=>o.groupId===id).length;if(!confirm(`確定要刪除這次開團嗎？將同步刪除 ${related} 筆訂單與歷史訂單資料。`))return;data.orders=data.orders.filter(o=>o.groupId!==id);data.groups=data.groups.filter(g=>g.id!==id);save();admin()}
function adminStores(){const categories=[...new Set(['飲料','主食',...data.stores.map(s=>s.category).filter(Boolean)])];const q=state.storeQuery||'',cat=state.storeCategory||'';const filtered=data.stores.filter(s=>(!q||(s.name+' '+s.note+' '+s.address+' '+s.items.map(i=>i.name).join(' ')).toLowerCase().includes(q.toLowerCase()))&&(!cat||s.category===cat));return `<h2 class="section-title">店家與菜單</h2><div class="card form"><label>店家名稱</label><input id="sname" placeholder="例如：好味便當"><div class="row"><div><label>分類</label><input id="scat" list="categoryList" placeholder="飲料、主食或自訂分類"><datalist id="categoryList">${categories.map(x=>`<option value="${esc(x)}">`).join('')}</datalist></div><div><label>店家電話</label><input id="sphone" type="tel" inputmode="tel" placeholder="例如：02-1234-5678"></div></div><label>店家地址</label><input id="saddress" placeholder="例如：台北市信義區市府路45號"><div class="hint">地址會自動帶入 Google 地圖，不需要設定金鑰。</div><label>取餐方式</label><input id="smethod" placeholder="例如：自取、外送、現場付款"><label>點餐備註</label><textarea id="snote" placeholder="辣度、取餐地點或其他提醒"></textarea><label>原始菜單（PDF／JPG／PNG）</label><input type="file" accept=".pdf,image/jpeg,image/png" onchange="importMenu(this)"><div class="filehint" id="filehint">可選，檔案上限 3.5MB</div><label>餐點內容（每行：品項/規格/價格）</label><textarea id="sitems" placeholder="雞腿飯/正常/120&#10;紅茶/小杯,大杯/25,35&#10;咖啡/冰、熱/60"></textarea><div class="hint">規格可用「逗號、頓號或 |」輸入兩種以上；價格可輸入單一價格（套用所有規格），或用「逗號、頓號或 |」逐一對應多個規格。</div><button class="btn full" style="margin-top:14px" onclick="createStore()">儲存店家</button></div><div class="card"><div class="filters"><input aria-label="關鍵字查詢" placeholder="搜尋店家、餐點、備註或地址" value="${esc(q)}" oninput="state.storeQuery=this.value;admin()"><select aria-label="分類查詢" onchange="state.storeCategory=this.value;admin()"><option value="">全部分類</option>${categories.map(x=>`<option ${cat===x?'selected':''}>${esc(x)}</option>`).join('')}</select></div><b>已建立店家（${filtered.length}）</b>${filtered.map(s=>`<div class="order"><b>${esc(s.name)}</b><span class="badge" style="float:right">${esc(s.category||'未分類')}</span><div class="small">${s.items.length} 個品項・${esc(s.phone||'未填電話')}・${esc(s.address||'未填地址')}・${esc(s.importName||'無附件')}</div><div class="adminlist" style="margin-top:7px"><button class="btn light smallbtn" onclick="previewStore('${s.id}')">預覽</button><button class="btn light smallbtn" onclick="editStore('${s.id}')">編輯</button><button class="btn danger smallbtn" onclick="deleteStore('${s.id}')">刪除</button></div></div>`).join('')||'<p class="small">沒有符合條件的店家</p>'}</div>`}
function splitMulti(v){return String(v||'').split(/[、,，|｜]/).map(x=>x.trim()).filter(Boolean)}
function parseItems(text){if(!/【[^】]+】|品項\s*[:：]|規格\s*[:：]/.test(text))return parseLegacyItems(text);let section='',current=null,items=[];for(const raw of text.split(/\r?\n/)){const line=raw.trim();if(!line)continue;const header=line.match(/^【\s*(.*?)\s*】$/);if(header){section=header[1];current=null;continue}const item=line.match(/^品項\s*[:：]\s*(.*?)(?:\s*=\s*(\d+(?:\.\d+)?))?$/);if(item){current={name:item[1].trim(),section,price:Number(item[2]||0),specs:'單一規格',optionGroups:[]};if(!current.name)return[];items.push(current);continue}if(/^規格\s*[:：]?$/.test(line))continue;const group=line.match(/^-\s*\[\s*(.*?)\s*\]\s*[:：]\s*(.*)$/);if(group&&current){const values=[],adjustments={};for(const part of splitMulti(group[2])){const [label,rawPrice]=part.split('=').map(x=>x.trim());if(!label)return[];values.push(label);if(rawPrice!==undefined){const n=Number(rawPrice.replace(/^\+/,''));if(!Number.isFinite(n))return[];adjustments[label]=n}}const pricing=/價格/.test(group[1])&&values.some(v=>Object.prototype.hasOwnProperty.call(adjustments,v)&&!String(group[2]).includes(v+'=+'));if(pricing&&values.some(v=>!Object.prototype.hasOwnProperty.call(adjustments,v)))return[];current.optionGroups.push({name:group[1],values,adjustments,pricing});continue}return[]}return items}
function parseLegacyItems(text){let section='',items=[];for(const raw of text.split(/\r?\n/)){const line=raw.trim();if(!line)continue;const header=line.match(/^\{\s*專區\s*\}\s*=\s*\{\s*(.*?)\s*\}$/);if(header){section=header[1];continue}const parts=line.split('/');if(parts.length<3)return[];const name=parts.shift().trim(),specText=parts.shift().trim(),priceText=parts.join('/').trim(),specs=splitMulti(specText),prices=splitMulti(priceText).map(x=>Number(x.replace(/[^\d.]/g,'')));if(!name||!specs.length||!prices.length||prices.some(Number.isNaN)||(prices.length!==1&&prices.length!==specs.length))return[];items.push({name,section,specs:specs.join('、'),price:prices[0],variants:specs.map((spec,i)=>({spec,price:prices.length===1?prices[0]:prices[i]}))})}return items}
function importMenu(el){const f=el.files[0];if(!f)return;if(f.size>3500000){alert('檔案請勿超過 3.5MB');el.value='';return}const reader=new FileReader();reader.onload=()=>{$('#filehint').textContent='已選擇：'+f.name;$('#filehint').dataset.file=f.name;$('#filehint').dataset.data=reader.result};reader.readAsDataURL(f)}
function createStore(){const name=$('#sname').value.trim(),raw=$('#sitems').value.trim(),items=parseItems(raw);if(!name)return alert('請輸入店家名稱');if(!items.length)return alert('餐點格式有誤。請依照下方說明輸入品項、規格與價格。');const id=$('#sname').dataset.id||crypto.randomUUID(),old=store(id)||{};const rec={...old,id,name,category:$('#scat').value.trim()||'未分類',phone:$('#sphone').value.trim(),address:$('#saddress').value.trim(),method:'',note:$('#snote').value.trim(),items,importName:$('#filehint').dataset.file||old.importName||'',importData:$('#filehint').dataset.data||old.importData||''};const i=data.stores.findIndex(s=>s.id===id);i<0?data.stores.push(rec):data.stores[i]=rec;save();state.storeQuery='';admin()}
function itemEditLine(item){const vs=variants(item);return `${item.name}/${vs.map(v=>v.spec).join(',')}/${vs.map(v=>v.price).join(',')}`}
function editStore(id){const s=store(id);state.adminTab=1;state.storeQuery='';state.storeCategory='';admin();$('#sname').value=s.name;$('#sname').dataset.id=s.id;$('#scat').value=s.category||'';$('#sphone').value=s.phone||'';$('#saddress').value=s.address||'';$('#smethod').value='';$('#snote').value=s.note||'';$('#sitems').value=s.items.map(item=>{const groups=optionGroups(item);if(item.priceByOption){const basic=groups.filter(g=>g.name!=='容量').map(g=>`(${g.name}；${g.values.join(',')})`).join(',');const cap=groups.find(g=>g.name==='容量');return `=${item.name}/${basic}/[${cap.values.join(',')}]/${cap.values.map(v=>item.priceByOption.prices[v]).join(',')}`}return `${item.section?`{專區}={${item.section}}\n`:''}${itemEditLine(item)}`}).join('\n');$('#filehint').textContent=s.importName?'目前附件：'+s.importName:'可選，檔案上限 3.5MB';$('#filehint').dataset.file=s.importName||'';$('#filehint').dataset.data=s.importData||'';window.scrollTo({top:0,behavior:'smooth'})}
function deleteStore(id){if(data.groups.some(g=>g.storeId===id))return alert('這間店已有開團紀錄，不能刪除');if(confirm('確定要刪除這間店嗎？')){data.stores=data.stores.filter(s=>s.id!==id);save();admin()}}
function previewStore(id){const s=store(id);$('#modal').innerHTML=`<div class="modal"><div class="modalbox"><button class="btn light smallbtn" style="float:right" onclick="closeModal()">關閉</button><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><p class="small">${esc(s.method||'')}${s.phone?(s.method?'・':'')+'電話 '+esc(s.phone):''}</p>${mapHtml(s.address)}${s.items.map(i=>`<div class="menu-item"><div class="grow"><b>${esc(i.name)}</b><div class="small">${variants(i).map(v=>`${esc(v.spec)} NT$ ${v.price.toLocaleString()}`).join('・')}</div></div></div>`).join('')}</div></div>`}
function showMenuFile(id){const s=store(id);const content=s.importData?.startsWith('data:application/pdf')?`<object data="${s.importData}" type="application/pdf" style="width:100%;height:65vh">無法預覽 PDF</object>`:`<img src="${s.importData}" alt="${esc(s.importName||'菜單')}" style="width:100%;max-height:70vh;object-fit:contain">`;$('#modal').innerHTML=`<div class="modal"><div class="modalbox" style="width:min(900px,100%)"><button class="btn light smallbtn" style="float:right" onclick="closeModal()">關閉</button><h2>${esc(s.name)}菜單</h2>${content}</div></div>`}
function adminOrders(){const tabs=`<div class="tabs" style="padding:0 0 14px"><button class="tab ${state.orderTab===0?'on':''}" onclick="state.orderTab=0;admin()">每次開團</button><button class="tab ${state.orderTab===1?'on':''}" onclick="state.orderTab=1;admin()">過往開團</button></div>`;return `<h2 class="section-title">訂單管理</h2>${tabs}${state.orderTab===0?currentOrdersAdmin():pastOrdersAdmin()}`}
function aggregate(os){const map={};os.forEach(o=>o.items.forEach(x=>{const k=x.name+'／'+(x.spec||'單一規格');map[k]=(map[k]||0)+(Number(x.qty)||0)}));return map}
function currentOrdersAdmin(){const date=state.orderDate||localDate(new Date());const groups=data.groups.filter(g=>localDate(g.createdAt)===date).sort((a,b)=>(store(a.storeId)?.name||'').localeCompare(store(b.storeId)?.name||'','zh-Hant'));const allOrders=groups.flatMap(g=>data.orders.filter(o=>o.groupId===g.id));return `<div class="card form"><label style="margin-top:0">開團日期</label><input type="date" value="${date}" onchange="state.orderDate=this.value;admin()"></div>${groups.map(g=>adminGroupCard(g,true)).join('')||'<div class="empty">這一天沒有開團紀錄</div>'}<div class="card total"><span>當日所有訂單總金額</span><span>NT$ ${allOrders.reduce((a,o)=>a+Number(o.total||0),0).toLocaleString()}</span></div>`}
function adminGroupCard(g){const s=store(g.storeId)||{},os=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>{const ai=a.items[0]?.name||'',bi=b.items[0]?.name||'';return ai.localeCompare(bi,'zh-Hant')||new Date(a.createdAt)-new Date(b.createdAt)}),summary=aggregate(os);return `<article class="card store-section"><div class="between"><div><h3>${esc(s.name||'已刪除店家')}${s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:''}</h3><div class="small">開團者：${esc(g.creator||'未填寫')}・${fmt(g.createdAt)}</div></div><button class="btn light smallbtn" onclick="openManualOrder('${g.id}')">＋ 新增訂單</button></div><div class="summary"><b>品項數量加總</b><br>${Object.entries(summary).sort(([a],[b])=>a.localeCompare(b,'zh-Hant')).map(([k,v])=>`${esc(k)} × ${v}`).join('<br>')||'尚無品項'}<br><b>訂單總金額：NT$ ${os.reduce((a,o)=>a+Number(o.total||0),0).toLocaleString()}</b></div>${os.map(o=>`<div class="order order-grid"><b>${esc(o.buyer)}</b><div class="details">${orderLines(o)}<div class="money">NT$ ${Number(o.total||0).toLocaleString()}</div></div><div class="adminlist"><button class="pill ${o.paid?'paid':'unpaid'}" onclick="togglePay('${o.id}')">${o.paid?'已付款':'未付款'}</button><button class="btn light smallbtn" onclick="removeOrder('${o.id}')">移除</button></div></div>`).join('')||'<p class="small">尚無訂單</p>'}</article>`}
function pastOrdersAdmin(){const groups=[...data.groups].sort((a,b)=>localDate(b.createdAt).localeCompare(localDate(a.createdAt))||(store(a.storeId)?.name||'').localeCompare(store(b.storeId)?.name||'','zh-Hant'));let last='';return groups.map(g=>{const d=localDate(g.createdAt),heading=d!==last?`<h3 class="date-heading">${fmt(g.createdAt,false)}</h3>`:'';last=d;return heading+adminGroupCard(g)}).join('')||'<div class="empty">尚無過往開團訂單</div>'}
function togglePay(id){const o=data.orders.find(x=>x.id===id);if(!o)return;o.paid=!o.paid;save();admin()}
function openManualOrder(groupId){const g=group(groupId),s=g&&store(g.storeId);if(!g||!s)return;$('#modal').innerHTML=`<div class="modal"><div class="modalbox form"><h2>手動新增訂單</h2><p class="small">${esc(s.name)}</p><label>訂購人</label><input id="manualBuyer" maxlength="30" placeholder="請輸入姓名"><label>餐點內容（每行：品項/規格/數量/單價）</label><textarea id="manualItems" placeholder="雞腿飯/正常/1/120&#10;紅茶/大杯/2/35"></textarea><div class="hint">單價會用於計算訂單總金額。</div><div class="row" style="margin-top:16px"><button class="btn light" onclick="closeModal()">取消</button><button class="btn" onclick="saveManualOrder('${groupId}')">新增訂單</button></div></div></div>`}
function saveManualOrder(groupId){const buyer=$('#manualBuyer').value.trim(),raw=$('#manualItems').value.trim();if(!buyer)return alert('請輸入訂購人');const items=raw.split(/\r?\n/).filter(Boolean).map(line=>{const [name,spec,qty,price]=line.split('/').map(x=>x.trim());return {name,spec,qty:Number(qty),price:Number(String(price||'').replace(/[^\d.]/g,''))}}).filter(x=>x.name&&x.spec&&Number.isFinite(x.qty)&&x.qty>0&&Number.isFinite(x.price)&&x.price>=0);if(!items.length||items.length!==raw.split(/\r?\n/).filter(Boolean).length)return alert('餐點格式有誤，請使用「品項/規格/數量/單價」。');data.orders.push({id:crypto.randomUUID(),groupId,buyer,items,total:items.reduce((sum,x)=>sum+x.qty*x.price,0),paid:false,createdAt:new Date().toISOString()});save();closeModal();admin()}
function removeOrder(id){if(!confirm('確定要移除這筆訂單嗎？此操作會同步更新歷史訂單。'))return;data.orders=data.orders.filter(o=>o.id!==id);save();admin()}
function adminSettings(){return `<h2 class="section-title">設定</h2><div class="card form"><label>變更管理密碼</label><input id="newpass" type="password" placeholder="至少 4 個字元"><button class="btn full" style="margin-top:14px" onclick="changePass()">儲存新密碼</button></div><div class="card"><b>資料同步</b><p class="small">系統會自動同步團購、店家與訂單資料；網路中斷時會先保存在此裝置。</p></div><div class="card"><div class="between"><b>App 版本</b><span class="badge">${APP_VERSION}</span></div><p class="small">${COPYRIGHT}</p><div class="adminlist"><button class="btn light smallbtn" onclick="showLegal('terms')">使用者條款</button><button class="btn light smallbtn" onclick="showLegal('privacy')">隱私權政策</button></div></div>`}
function showLegal(kind){const terms=`使用者條款\n\n1. 本服務用於團購點餐與訂單管理。\n2. 使用者應提供正確的訂購資料，並自行確認餐點、數量與付款狀態。\n3. 管理者負責管理店家、開團、付款追蹤及團購資料。\n4. 未經授權不得干擾、破壞或嘗試存取他人資料。\n5. 本服務得依功能維護需要更新內容。`;const privacy=`隱私權政策\n\n1. 為提供團購功能，系統會儲存店家資料、開團資訊、訂購人名稱、餐點內容、數量與付款狀態。\n2. 資料會同步至本服務使用的雲端資料庫，供同一團購的使用者與管理者讀取。\n3. 請勿在訂單欄位輸入身分證號、銀行帳號或其他不必要的敏感資料。\n4. 資料僅用於團購點餐、付款追蹤與服務維護；不作廣告販售用途。\n5. 如需更正或刪除資料，請聯絡團購管理者處理。`;const title=kind==='privacy'?'隱私權政策':'使用者條款';$('#modal').innerHTML=`<div class="modal"><div class="modalbox"><button class="btn light smallbtn" style="float:right" onclick="closeModal()">關閉</button><h2>${title}</h2><div class="legal small">${esc(kind==='privacy'?privacy:terms)}</div><hr class="divider"><div class="small">${APP_VERSION}・${COPYRIGHT}</div></div></div>`}
function changePass(){const p=$('#newpass').value;if(p.length<4)return alert('密碼至少需要 4 個字元');data.password=p;save();alert('密碼已更新')}
function closeModal(){$('#modal').innerHTML=''}
function showOrderSuccess(){$('#modal').innerHTML=`<div class="modal"><div class="modalbox notice"><div class="success-icon" aria-label="成功">✓</div><h2>點餐完成</h2><p>您的訂單已成功送出。</p><div class="success-actions"><button class="btn full" id="viewOrder">查看訂單</button><button class="btn outline full" id="continueOrder">繼續點餐</button></div></div></div>`;$('#viewOrder').onclick=()=>{closeModal();go('history')};$('#continueOrder').onclick=()=>{closeModal();go('menu')}}
function startOrderItem(i){state.cart={};state.buyer='';state.focusItem=i;state.selectedItem=i;go('order')}
function sectionedMenuItems(items){const sections=new Map();items.forEach((item,index)=>{const key=item.section||'';if(!sections.has(key))sections.set(key,[]);sections.get(key).push({item,index})});return [...sections].map(([section,rows])=>`${section?`<h3 class="date-heading">${esc(section)}</h3>`:''}${rows.map(({item,index})=>`<div class="menu-item pick-item" role="button" tabindex="0" onclick="startOrderItem(${index})" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();startOrderItem(${index})}"><div class="food-icon">${item.category==='飲料'?'🧋':'🍱'}</div><div class="grow"><div class="name">${esc(item.name)}</div><div class="small">${variants(item).map(v=>`${esc(v.spec)} NT$ ${v.price.toLocaleString()}`).join('・')}</div><div class="pick-hint">點此選擇此品項 →</div></div></div>`).join('')}`).join('')}
function menu(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}$('#headline').textContent=s.name;$('#view').innerHTML=`<button class="btn light" onclick="go('home')">返回團購</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<hr class="divider">${sectionedMenuItems(s.items)||'<p class="small">這間店尚未建立餐點。</p>'}<button class="btn full" style="margin-top:14px" onclick="state.cart={};state.buyer='';state.focusItem=null;go('order')">開始點餐</button></div>`}
function orderForm(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}const lines=s.items.map((item,i)=>{const vs=variants(item),groups=optionGroups(item),c=cartEntry(item,i),price=groups.length?selectedPrice(item,c):(vs[c.variant]?.price||0);const controls=groups.length?groups.map(gr=>`<label class="small" style="margin-top:8px">${esc(gr.name)}（必選）</label><select aria-label="${esc(item.name)}${esc(gr.name)}" onchange="setOption(${i},'${esc(gr.name)}',this.value)">${gr.values.map(v=>`<option ${c.options[gr.name]===v?'selected':''}>${esc(v)}</option>`).join('')}</select>`).join(''):`<label class="small" style="margin-top:8px">規格</label><select aria-label="${esc(item.name)}規格" onchange="setVariant(${i},this.value)">${vs.map((v,j)=>`<option value="${j}" ${Number(c.variant)===j?'selected':''}>${esc(v.spec)}</option>`).join('')}</select>`;return `<div id="orderItem${i}" class="menu-item"><div class="grow"><div class="small">品項</div><div class="name">${esc(item.name)}</div>${controls}<div class="small" style="margin-top:8px">價錢</div><div class="price">NT$ ${price.toLocaleString()}</div></div><div class="qty"><button ${!c.q?'disabled':''} onclick="changeQty(${i},-1)">−</button><b>${c.q||0}</b><button onclick="changeQty(${i},1)">＋</button></div></div>`}).join('');$('#headline').textContent='填寫訂單';$('#view').innerHTML=`<button class="btn light" onclick="go('menu')">返回菜單</button><div class="card form" style="margin-top:14px"><label>訂購人 <em style="color:var(--danger)">*</em></label><input id="buyer" maxlength="30" placeholder="請輸入姓名" value="${esc(state.buyer||'')}" oninput="state.buyer=this.value"><label>品項</label>${lines}<div class="total"><span>訂單總金額</span><span id="total">NT$ 0</span></div><button class="btn full" onclick="submitOrder()">送出訂單</button></div>`;updateTotal();if(state.focusItem!==null){const target=$('#orderItem'+state.focusItem);target?.scrollIntoView({behavior:'smooth',block:'center'});state.focusItem=null}}
function serializeBlockItems(items){let section=null,lines=[];for(const item of items){if(item.section!==section){section=item.section;lines.push(`【${section||'未分類'}】`)}if(!optionGroups(item).length){lines.push(`${item.name}/${variants(item).map(v=>v.spec).join(',')}/${variants(item).map(v=>v.price).join(',')}`);continue}lines.push(`品項：${item.name}${item.price?` = ${item.price}`:''}`,'規格:');optionGroups(item).forEach(g=>{const choices=g.values.map(v=>{if(!Object.prototype.hasOwnProperty.call(g.adjustments||{},v))return v;const n=g.adjustments[v];return `${v}=${g.pricing?n:`+${n}`}`}).join(', ');lines.push(`- [${g.name}]：${choices}`)})}return lines.join('\n')}
function editStore(id){const s=store(id);state.adminTab=1;state.storeQuery='';state.storeCategory='';admin();$('#sname').value=s.name;$('#sname').dataset.id=s.id;$('#scat').value=s.category||'';$('#sphone').value=s.phone||'';$('#saddress').value=s.address||'';$('#smethod').value='';$('#snote').value=s.note||'';$('#sitems').value=serializeBlockItems(s.items);$('#filehint').textContent=s.importName?'目前附件：'+s.importName:'可選，檔案上限 3.5MB';$('#filehint').dataset.file=s.importName||'';$('#filehint').dataset.data=s.importData||'';window.scrollTo({top:0,behavior:'smooth'})}
function adminOrderLines(o){return o.items.map(x=>{const price=Number(x.price||0),qty=Number(x.qty)||0;return `<div class="history-item"><span class="history-text">${esc(x.name)}／${esc(historySpec(x.spec))}</span><span class="history-price">$${price.toLocaleString()}</span><span class="history-qty">× ${qty}</span><span class="history-price">總額 $${(price*qty).toLocaleString()}</span></div>`}).join('')}
function adminGroupCard(g){const s=store(g.storeId)||{},os=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>{const ai=a.items[0]?.name||'',bi=b.items[0]?.name||'';return ai.localeCompare(bi,'zh-Hant')||new Date(a.createdAt)-new Date(b.createdAt)}),summary=aggregate(os);return `<article class="card store-section"><div class="between"><div><h3>${esc(s.name||'已刪除店家')}${s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:''}</h3><div class="small">開團者：${esc(g.creator||'未填寫')}・${fmt(g.createdAt)}</div></div><button class="btn light smallbtn" onclick="openManualOrder('${g.id}')">＋ 新增訂單</button></div><div class="summary"><b>品項數量加總</b><br>${Object.entries(summary).sort(([a],[b])=>a.localeCompare(b,'zh-Hant')).map(([k,v])=>`${esc(k)} × ${v}`).join('<br>')||'尚無品項'}<br><b>訂單總金額：NT$ ${os.reduce((a,o)=>a+Number(o.total||0),0).toLocaleString()}</b></div>${os.map(o=>`<div class="order order-grid"><b>${esc(o.buyer)}</b><div class="details">${adminOrderLines(o)}</div><div class="adminlist"><button class="pill ${o.paid?'paid':'unpaid'}" onclick="togglePay('${o.id}')">${o.paid?'已付款':'未付款'}</button><button class="btn light smallbtn" onclick="removeOrder('${o.id}')">移除</button></div></div>`).join('')||'<p class="small">尚無訂單</p>'}</article>`}
function adminSummaryLines(os){const rows=new Map();os.forEach(o=>o.items.forEach(x=>{const price=Number(x.price||0),key=[x.name,x.spec||'',price].join('\u0001'),row=rows.get(key)||{name:x.name,spec:x.spec||'',price,qty:0};row.qty+=Number(x.qty)||0;rows.set(key,row)}));return [...rows.values()].sort((a,b)=>a.name.localeCompare(b.name,'zh-Hant')).map(x=>`<div class="small" style="margin-top:3px;color:var(--ink)">${esc(x.name)}／${esc(historySpec(x.spec))} <b>× ${x.qty}</b></div>`).join('')||'尚無品項'}
function adminGroupCard(g){const s=store(g.storeId)||{},os=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>{const ai=a.items[0]?.name||'',bi=b.items[0]?.name||'';return ai.localeCompare(bi,'zh-Hant')||new Date(a.createdAt)-new Date(b.createdAt)});return `<article class="card store-section"><div class="between"><div><h3>${esc(s.name||'已刪除店家')}${s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:''}</h3><div class="small">開團者：${esc(g.creator||'未填寫')}・${fmt(g.createdAt)}</div></div><button class="btn light smallbtn" onclick="openManualOrder('${g.id}')">＋ 新增訂單</button></div><div class="summary"><b>品項數量加總</b>${adminSummaryLines(os)}<br><b>訂單總金額：NT$ ${os.reduce((a,o)=>a+Number(o.total||0),0).toLocaleString()}</b></div>${os.map(o=>`<div class="order order-grid"><b>${esc(o.buyer)}</b><div class="details">${adminOrderLines(o)}</div><div class="adminlist"><button class="pill ${o.paid?'paid':'unpaid'}" onclick="togglePay('${o.id}')">${o.paid?'已付款':'未付款'}</button><button class="btn light smallbtn" onclick="removeOrder('${o.id}')">移除</button></div></div>`).join('')||'<p class="small">尚無訂單</p>'}</article>`}
function startAllOrder(){state.cart={};state.buyer='';state.focusItem=null;state.selectedItem=null;go('order')}
function menu(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}$('#headline').textContent=s.name;$('#view').innerHTML=`<button class="btn light" onclick="go('home')">返回團購</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<hr class="divider">${sectionedMenuItems(s.items)||'<p class="small">這間店尚未建立餐點。</p>'}<button class="btn full" style="margin-top:14px" onclick="startAllOrder()">開始點餐</button></div>`}
function orderForm(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}const visible=s.items.map((item,i)=>({item,i})).filter(x=>state.selectedItem===null||x.i===state.selectedItem);const lines=visible.map(({item,i})=>{const vs=variants(item),groups=optionGroups(item),c=cartEntry(item,i),price=groups.length?selectedPrice(item,c):(vs[c.variant]?.price||0),controls=groups.length?groups.map(gr=>`<label class="small" style="margin-top:8px">${esc(gr.name)}（必選）</label><select aria-label="${esc(item.name)}${esc(gr.name)}" onchange="setOption(${i},'${esc(gr.name)}',this.value)">${gr.values.map(v=>`<option ${c.options[gr.name]===v?'selected':''}>${esc(v)}</option>`).join('')}</select>`).join(''):`<label class="small" style="margin-top:8px">規格</label><select aria-label="${esc(item.name)}規格" onchange="setVariant(${i},this.value)">${vs.map((v,j)=>`<option value="${j}" ${Number(c.variant)===j?'selected':''}>${esc(v.spec)}</option>`).join('')}</select>`;return `<div id="orderItem${i}" class="menu-item"><div class="grow"><div class="small">品項</div><div class="name">${esc(item.name)}</div>${controls}<div class="small" style="margin-top:8px">價錢</div><div class="price">NT$ ${price.toLocaleString()}</div></div><div class="qty"><button ${!c.q?'disabled':''} onclick="changeQty(${i},-1)">−</button><b>${c.q||0}</b><button onclick="changeQty(${i},1)">＋</button></div></div>`}).join('');$('#headline').textContent='填寫訂單';$('#view').innerHTML=`<button class="btn light" onclick="go('menu')">返回菜單</button><div class="card form" style="margin-top:14px"><label>訂購人 <em style="color:var(--danger)">*</em></label><input id="buyer" maxlength="30" placeholder="請輸入姓名" value="${esc(state.buyer||'')}" oninput="state.buyer=this.value"><label>品項</label>${lines}<div class="total"><span>訂單總金額</span><span id="total">NT$ 0</span></div><button class="btn full" onclick="submitOrder()">送出訂單</button></div>`;updateTotal();if(state.focusItem!==null){$('#orderItem'+state.focusItem)?.scrollIntoView({behavior:'smooth',block:'center'});state.focusItem=null}}
function setMenuSection(section){state.menuSection=section;menu()}
function sectionedMenuItems(items){const sections=new Map();items.forEach((item,index)=>{const key=item.section||'其他';if(!sections.has(key))sections.set(key,[]);sections.get(key).push({item,index:item._menuIndex??index})});return [...sections].map(([section,rows])=>`${section?`<h3 class="date-heading">${esc(section)}</h3>`:''}${rows.map(({item,index})=>`<div class="menu-item pick-item" role="button" tabindex="0" onclick="startOrderItem(${index})" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();startOrderItem(${index})}"><div class="food-icon">${item.category==='飲料'?'🧋':'🍱'}</div><div class="grow"><div class="name">${esc(item.name)}</div><div class="small">${variants(item).map(v=>`${esc(v.spec)} NT$ ${v.price.toLocaleString()}`).join('・')}</div><div class="pick-hint">點此選擇此品項 →</div></div></div>`).join('')}`).join('')}
function menu(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}const sections=[...new Set(s.items.map(x=>x.section||'其他'))];if(!sections.includes(state.menuSection))state.menuSection=sections[0]||null;const listed=s.items.map((x,i)=>Object.assign({},x,{_menuIndex:i})).filter(x=>!state.menuSection||(x.section||'其他')===state.menuSection);const tabs=sections.length>1?`<div class="tabs" style="padding:0 0 12px">${sections.map(section=>`<button class="tab ${state.menuSection===section?'on':''}" onclick="setMenuSection(${JSON.stringify(section)})">${esc(section)}</button>`).join('')}</div>`:'';$('#headline').textContent=s.name;$('#view').innerHTML=`<button class="btn light" onclick="go('home')">返回團購</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<hr class="divider">${tabs}${sectionedMenuItems(listed)||'<p class="small">這間店尚未建立餐點。</p>'}<button class="btn full" style="margin-top:14px" onclick="startAllOrder()">開始點餐</button></div>`}
if('serviceWorker' in navigator)navigator.serviceWorker.register('./sw.js');
function menu(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}const sections=[...new Set(s.items.map(x=>x.section||'其他'))];if(!sections.includes(state.menuSection))state.menuSection=sections[0]||null;const listed=s.items.map((x,i)=>Object.assign({},x,{_menuIndex:i})).filter(x=>!state.menuSection||(x.section||'其他')===state.menuSection);const tabs=sections.length>1?`<div class="tabs" style="padding:0 0 12px">${sections.map(section=>`<button class="tab ${state.menuSection===section?'on':''}" data-section="${esc(section)}" onclick="setMenuSection(this.dataset.section)">${esc(section)}</button>`).join('')}</div>`:'';$('#headline').textContent=s.name;$('#view').innerHTML=`<button class="btn light" onclick="go('home')">返回團購</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<hr class="divider">${tabs}${sectionedMenuItems(listed)||'<p class="small">這間店尚未建立餐點。</p>'}<button class="btn full" style="margin-top:14px" onclick="startAllOrder()">開始點餐</button></div>`}
function menu(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}const namedSections=[...new Set(s.items.map(x=>x.section||'其他'))],sections=['全部商品',...namedSections];if(!sections.includes(state.menuSection))state.menuSection='全部商品';const listed=s.items.map((x,i)=>Object.assign({},x,{_menuIndex:i})).filter(x=>state.menuSection==='全部商品'||(x.section||'其他')===state.menuSection);const tabs=sections.length>2?`<div class="tabs" style="padding:0 0 12px">${sections.map(section=>`<button class="tab ${state.menuSection===section?'on':''}" data-section="${esc(section)}" onclick="setMenuSection(this.dataset.section)">${esc(section)}</button>`).join('')}</div>`:'';$('#headline').textContent=s.name;$('#view').innerHTML=`<button class="btn light" onclick="go('home')">返回團購</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<hr class="divider">${tabs}${sectionedMenuItems(listed)||'<p class="small">這間店尚未建立餐點。</p>'}<button class="btn full" style="margin-top:14px" onclick="startAllOrder()">開始點餐</button></div>`}
function home(){const active=data.groups.filter(isOpen).sort((a,b)=>new Date(a.deadline)-new Date(b.deadline));$('#headline').textContent=active.length?`目前有 ${active.length} 個訂單進行中`:'目前沒有開放中的訂單';$('#view').innerHTML=active.length?active.map(g=>{const s=store(g.storeId)||{};return `<article class="card"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name||'已刪除店家')}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><b class="deadline open">開放中</b></div><div class="deadline">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div><button class="btn full" onclick="state.group='${g.id}';go('menu')">查看菜單／點餐</button></article>`}).join(''):`<div class="empty"><b>現在沒有開放中的訂單</b>管理者開團後，就可以在這裡開始點餐。</div>`}

/* 2026-07 quick-menu enhancement */
state.storeBuildMode=state.storeBuildMode||'full';
state.quickRows=state.quickRows||[];

function reqMark(){return ' <em class="required">*</em>'}
function setStoreBuildMode(mode){
  state.storeBuildMode=mode;
  document.querySelectorAll('.build-method').forEach(x=>x.classList.toggle('on',x.dataset.mode===mode));
  $('#fullMenuFields')?.classList.toggle('hidden',mode==='quick');
  $('#quickMenuHelp')?.classList.toggle('hidden',mode!=='quick');
}
function adminGroups(){
  const rows=[...data.groups].sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));
  return `<h2 class="section-title">開團管理</h2><div class="card form">
  <label>選擇店家${reqMark()}</label><select id="gstore">${data.stores.map(s=>`<option value="${s.id}">${esc(s.name)}（${esc(s.category||'未分類')}）</option>`).join('')||'<option value="">請先建立店家</option>'}</select>
  <label>開團者（選填）</label><input id="gcreator" maxlength="30" placeholder="可不填寫">
  <label>付款者（選填）</label><input id="gpayee" maxlength="30" placeholder="可不填寫">
  <label>收單時間${reqMark()}</label><input id="deadline" type="datetime-local">
  <button class="btn full" style="margin-top:14px" onclick="createGroup()">建立新團購</button></div>
  <div class="card"><b>開團紀錄</b>${rows.map(g=>`<div class="order"><b>${esc(store(g.storeId)?.name||'已刪除店家')}</b><span class="pill ${isOpen(g)?'paid':'unpaid'}" style="float:right">${isOpen(g)?'開放中':'已結束'}</span><div class="small">開團者：${esc(g.creator||'未填寫')}・付款者：${esc(g.payee||'未填寫')}・收單 ${fmt(g.deadline)}</div><div class="adminlist" style="margin-top:8px"><button class="btn light smallbtn" onclick="editGroup('${g.id}')">編輯</button>${isOpen(g)?`<button class="btn dark smallbtn" onclick="manualClose('${g.id}')">立即收單</button>`:''}<button class="btn danger smallbtn" onclick="deleteGroup('${g.id}')">刪除開團</button></div></div>`).join('')||'<p class="small">尚無開團紀錄</p>'}</div>`;
}
function createGroup(){
  if(!data.stores.length)return alert('請先建立店家');
  const d=$('#deadline').value,creator=$('#gcreator').value.trim(),payee=$('#gpayee').value.trim();
  if(!d)return alert('請選擇收單時間');
  const iso=new Date(d).toISOString();
  if(new Date(iso)<=now())return alert('收單時間必須晚於現在');
  data.groups.push({id:crypto.randomUUID(),storeId:$('#gstore').value,creator,payee,deadline:iso,createdAt:new Date().toISOString(),manualClosed:false});
  save();admin();
}
function editGroup(id){
  const g=group(id),d=new Date(g.deadline),v=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}T${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
  $('#modal').innerHTML=`<div class="modal"><div class="modalbox form"><h2>編輯團購</h2><label>開團者（選填）</label><input id="editCreator" value="${esc(g.creator||'')}"><label>付款者（選填）</label><input id="editPayee" value="${esc(g.payee||'')}"><label>收單時間${reqMark()}</label><input id="editDeadline" type="datetime-local" value="${v}"><div class="row" style="margin-top:16px"><button class="btn light" onclick="closeModal()">取消</button><button class="btn" onclick="saveGroupEdit('${id}')">儲存並重新開放</button></div></div></div>`;
}
function saveGroupEdit(id){
  const g=group(id),creator=$('#editCreator').value.trim(),payee=$('#editPayee').value.trim(),d=$('#editDeadline').value;
  if(!d)return alert('請選擇收單時間');
  const iso=new Date(d).toISOString();
  if(new Date(iso)<=now())return alert('收單時間必須晚於現在');
  g.creator=creator;g.payee=payee;g.deadline=iso;g.manualClosed=false;save();closeModal();admin();
}

function adminStores(){
  const categories=[...new Set(['飲料','主食',...data.stores.map(s=>s.category).filter(Boolean)])],q=state.storeQuery||'',cat=state.storeCategory||'';
  const filtered=data.stores.filter(s=>(!q||(s.name+' '+s.note+' '+s.address+' '+s.items.map(i=>i.name).join(' ')).toLowerCase().includes(q.toLowerCase()))&&(!cat||s.category===cat));
  const mode=state.storeBuildMode||'full';
  return `<h2 class="section-title">店家與菜單</h2><div class="card form">
  <label>建立店家方式</label>
  <div class="build-methods">
    <div class="build-method ${mode==='full'?'on':''}" data-mode="full" onclick="setStoreBuildMode('full')"><b>方式 1｜建立完整菜單</b><span class="small">輸入餐點、規格與價格，訂購人直接選擇。</span></div>
    <div class="build-method ${mode==='quick'?'on':''}" data-mode="quick" onclick="setStoreBuildMode('quick')"><b>方式 2｜只上傳原始菜單</b><span class="small">適合臨時開團，由訂購人自行輸入商品。</span></div>
  </div>
  <label>店家名稱${reqMark()}</label><input id="sname" placeholder="例如：好味便當">
  <div class="row"><div><label>分類（選填）</label><input id="scat" list="categoryList" placeholder="飲料、主食或自訂分類"><datalist id="categoryList">${categories.map(x=>`<option value="${esc(x)}">`).join('')}</datalist></div><div><label>店家電話（選填）</label><input id="sphone" type="tel" inputmode="tel" placeholder="例如：02-1234-5678"></div></div>
  <label>店家地址（選填）</label><input id="saddress" placeholder="例如：台北市信義區市府路45號"><div class="hint">地址會自動帶入 Google 地圖，不需要設定金鑰。</div>
  <label>餐點備註（選填）</label><textarea id="snote" placeholder="辣度、取餐地點或其他提醒"></textarea>
  <label>原始菜單（選填，PDF／JPG／PNG）</label><input type="file" accept=".pdf,image/jpeg,image/png" onchange="importMenu(this)"><div class="filehint" id="filehint">可選，檔案上限 3.5MB</div>
  <div id="quickMenuHelp" class="summary ${mode==='quick'?'':'hidden'}"><b>快速開團模式</b><br>儲存後，開放點餐頁會顯示原始菜單，訂購人自行填寫品項、規格、數量與單價。</div>
  <div id="fullMenuFields" class="${mode==='full'?'':'hidden'}"><label>餐點內容${reqMark()}（每行：品項/規格/價格）</label><textarea id="sitems" placeholder="雞腿飯/正常/120&#10;紅茶/小杯,大杯/25,35&#10;咖啡/冰、熱/60"></textarea><div class="hint">規格可用「逗號、頓號或 |」輸入兩種以上；價格可輸入單一價格，或逐一對應多個規格。</div></div>
  <button class="btn full" style="margin-top:14px" onclick="createStore()">儲存店家</button></div>
  <div class="card"><div class="filters"><input aria-label="關鍵字查詢" placeholder="搜尋店家、餐點、備註或地址" value="${esc(q)}" oninput="state.storeQuery=this.value;admin()"><select aria-label="分類查詢" onchange="state.storeCategory=this.value;admin()"><option value="">全部分類</option>${categories.map(x=>`<option ${cat===x?'selected':''}>${esc(x)}</option>`).join('')}</select></div><b>已建立店家（${filtered.length}）</b>${filtered.map(s=>`<div class="order"><b>${esc(s.name)}</b>${s.quickMenu?'<span class="badge" style="float:right">原始菜單點餐</span>':`<span class="badge" style="float:right">${esc(s.category||'未分類')}</span>`}<div class="small">${s.quickMenu?'訂購人自行輸入品項':s.items.length+' 個品項'}・${esc(s.phone||'未填電話')}・${esc(s.address||'未填地址')}・${esc(s.importName||'無附件')}</div><div class="adminlist" style="margin-top:7px"><button class="btn light smallbtn" onclick="previewStore('${s.id}')">預覽</button><button class="btn light smallbtn" onclick="editStore('${s.id}')">編輯</button><button class="btn danger smallbtn" onclick="deleteStore('${s.id}')">刪除</button></div></div>`).join('')||'<p class="small">沒有符合條件的店家</p>'}</div>`;
}
function createStore(){
  const name=$('#sname').value.trim(),mode=state.storeBuildMode||'full',raw=$('#sitems')?.value.trim()||'',items=mode==='full'?parseItems(raw):[];
  if(!name)return alert('請輸入店家名稱');
  if(mode==='full'&&!items.length)return alert('餐點格式有誤。請依照說明輸入品項、規格與價格。');
  const id=$('#sname').dataset.id||crypto.randomUUID(),old=store(id)||{};
  const importName=$('#filehint').dataset.file||old.importName||'',importData=$('#filehint').dataset.data||old.importData||'';
  if(mode==='quick'&&!importData)return alert('使用「只上傳原始菜單」時，請先上傳菜單檔案');
  const rec={...old,id,name,category:$('#scat').value.trim()||'',phone:$('#sphone').value.trim(),address:$('#saddress').value.trim(),method:'',note:$('#snote').value.trim(),items,quickMenu:mode==='quick',importName,importData};
  const i=data.stores.findIndex(s=>s.id===id);i<0?data.stores.push(rec):data.stores[i]=rec;save();state.storeQuery='';state.storeBuildMode='full';admin();
}
function editStore(id){
  const s=store(id);state.adminTab=1;state.storeQuery='';state.storeCategory='';state.storeBuildMode=s.quickMenu?'quick':'full';admin();
  $('#sname').value=s.name;$('#sname').dataset.id=s.id;$('#scat').value=s.category||'';$('#sphone').value=s.phone||'';$('#saddress').value=s.address||'';$('#snote').value=s.note||'';
  if($('#sitems'))$('#sitems').value=serializeBlockItems(s.items||[]);
  $('#filehint').textContent=s.importName?'目前附件：'+s.importName:'可選，檔案上限 3.5MB';$('#filehint').dataset.file=s.importName||'';$('#filehint').dataset.data=s.importData||'';setStoreBuildMode(state.storeBuildMode);window.scrollTo({top:0,behavior:'smooth'});
}
function previewStore(id){
 const s=store(id);
 const body=s.quickMenu?`<div class="summary">此店家採「原始菜單點餐」，訂購人會自行輸入商品。</div>${s.importData?`<button class="btn light full" onclick="closeModal();showMenuFile('${s.id}')">查看原始菜單</button>`:''}`:s.items.map(i=>`<div class="menu-item"><div class="grow"><b>${esc(i.name)}</b><div class="small">${variants(i).map(v=>`${esc(v.spec)} NT$ ${v.price.toLocaleString()}`).join('・')}</div></div></div>`).join('');
 $('#modal').innerHTML=`<div class="modal"><div class="modalbox"><button class="btn light smallbtn" style="float:right" onclick="closeModal()">關閉</button><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><p class="small">${s.phone?'電話 '+esc(s.phone):''}</p>${mapHtml(s.address)}${body}</div></div>`;
}

function menu(){
 const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}
 $('#headline').textContent=s.name;
 if(s.quickMenu){
   $('#view').innerHTML=`<button class="btn light" onclick="go('home')">返回團購</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<div class="summary"><b>臨時菜單點餐</b><br>請查看原始菜單，再自行填寫訂購商品。</div><button class="btn full" onclick="startQuickOrder()">開始點餐</button></div>`;return;
 }
 const namedSections=[...new Set(s.items.map(x=>x.section||'其他'))],sections=['全部商品',...namedSections];if(!sections.includes(state.menuSection))state.menuSection='全部商品';
 const listed=s.items.map((x,i)=>Object.assign({},x,{_menuIndex:i})).filter(x=>state.menuSection==='全部商品'||(x.section||'其他')===state.menuSection);
 const tabs=sections.length>2?`<div class="tabs" style="padding:0 0 12px">${sections.map(section=>`<button class="tab ${state.menuSection===section?'on':''}" data-section="${esc(section)}" onclick="setMenuSection(this.dataset.section)">${esc(section)}</button>`).join('')}</div>`:'';
 $('#view').innerHTML=`<button class="btn light" onclick="go('home')">返回團購</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${s.phone?'電話 '+esc(s.phone):''}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<hr class="divider">${tabs}${sectionedMenuItems(listed)||'<p class="small">這間店尚未建立餐點。</p>'}</div>`;
}
function startQuickOrder(){state.quickRows=[{name:'',spec:'',qty:1,price:''}];state.buyer='';go('order')}
function quickRowsHtml(){return state.quickRows.map((r,i)=>`<div class="quick-row"><div class="quick-grid"><div class="wide"><label>品項${reqMark()}</label><input value="${esc(r.name)}" oninput="quickSet(${i},'name',this.value)" placeholder="例如：雞腿飯"></div><div><label>規格（選填）</label><input value="${esc(r.spec)}" oninput="quickSet(${i},'spec',this.value)" placeholder="例如：大份"></div><div><label>數量${reqMark()}</label><input type="number" min="1" step="1" inputmode="numeric" value="${r.qty}" oninput="quickSet(${i},'qty',this.value)"></div><div><label>單價${reqMark()}</label><input type="number" min="0" step="1" inputmode="decimal" value="${esc(r.price)}" oninput="quickSet(${i},'price',this.value)" placeholder="0"></div><button class="btn danger smallbtn quick-remove" ${state.quickRows.length===1?'disabled':''} onclick="removeQuickRow(${i})">移除</button></div></div>`).join('')}
function quickSet(i,key,value){state.quickRows[i][key]=value;updateQuickTotal()}
function addQuickRow(){state.quickRows.push({name:'',spec:'',qty:1,price:''});quickOrderForm()}
function removeQuickRow(i){if(state.quickRows.length===1)return;state.quickRows.splice(i,1);quickOrderForm()}
function updateQuickTotal(){const total=state.quickRows.reduce((sum,r)=>sum+(Number(r.qty)||0)*(Number(r.price)||0),0);if($('#quickTotal'))$('#quickTotal').textContent='NT$ '+total.toLocaleString()}
function quickOrderForm(){
 const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');
 $('#headline').textContent='填寫訂單';
 $('#view').innerHTML=`<button class="btn light" onclick="go('menu')">返回菜單</button><div class="card form" style="margin-top:14px">${s.importData?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看原始菜單</button>`:''}<label>訂購人${reqMark()}</label><input id="buyer" maxlength="30" placeholder="請輸入姓名" value="${esc(state.buyer||'')}" oninput="state.buyer=this.value"><div class="between" style="margin-top:16px"><b>訂購商品</b><button class="btn light smallbtn" onclick="addQuickRow()">＋ 新增品項</button></div>${quickRowsHtml()}<div class="total"><span>總金額</span><span id="quickTotal">NT$ 0</span></div><button class="btn full" onclick="submitQuickOrder()">送出訂單</button></div>`;updateQuickTotal();
}

async function submitQuickOrder(){
 const g=group(state.group);if(!isOpen(g)){alert('這個團購已經結束');return go('home')}
 const buyer=$('#buyer').value.trim();if(!buyer)return alert('請輸入訂購人');
 const items=state.quickRows.map(r=>({name:String(r.name||'').trim(),spec:String(r.spec||'').trim()||'未填規格',qty:Number(r.qty),price:Number(r.price)}));
 if(items.some(x=>!x.name))return alert('請完整填寫每一筆品項');
 if(items.some(x=>!Number.isInteger(x.qty)||x.qty<1))return alert('數量必須為 1 以上的整數');
 if(items.some(x=>!Number.isFinite(x.price)||x.price<0))return alert('請填寫正確的單價');
 const newOrder={id:crypto.randomUUID(),groupId:g.id,buyer,items,total:items.reduce((a,x)=>a+x.qty*x.price,0),paid:false,createdAt:new Date().toISOString()};
 try{const r=await fetch(SUPABASE_URL+'/rest/v1/rpc/append_together_order',{method:'POST',headers,body:JSON.stringify({new_order:newOrder})});if(!r.ok)throw new Error(await r.text());data=normalize(await r.json());localStorage.setItem(KEY,JSON.stringify(data))}
 catch(e){data.orders.push(newOrder);save()}
 state.quickRows=[];showOrderSuccess();
}
function render(){
 const p=state.page;$('#tabs').classList.add('hidden');$('#adminBar').classList.add('hidden');
 document.querySelectorAll('.nav').forEach((x,i)=>x.classList.toggle('on',(p==='home'&&i===0)||(p==='history'&&i===1)||(p==='admin'&&i===2)));
 if(p==='home')home();else if(p==='menu')menu();else if(p==='order'){const s=store(group(state.group)?.storeId);s?.quickMenu?quickOrderForm():orderForm()}else if(p==='history')history();else admin();
}

render();loadSharedState();setInterval(()=>{if(state.page==='home'||state.page==='history')loadSharedState()},12000);

let jjSignatureTimer=null;
function syncAdminSignature(){
  const signature=document.querySelector('.jj-signature');
  const adminBar=document.querySelector('#adminBar');
  if(!signature||!adminBar)return;
  clearTimeout(jjSignatureTimer);
  signature.classList.remove('show');
  if(!adminBar.classList.contains('hidden')){
    jjSignatureTimer=setTimeout(()=>{
      if(!adminBar.classList.contains('hidden')) signature.classList.add('show');
    },2000);
  }
}
document.addEventListener('DOMContentLoaded',()=>{
  const adminBar=document.querySelector('#adminBar');
  if(adminBar){
    new MutationObserver(syncAdminSignature).observe(adminBar,{attributes:true,attributeFilter:['class']});
  }
  syncAdminSignature();
});

function pendingMenuFiles(){try{return JSON.parse($('#filehint')?.dataset.files||'[]')}catch{return[]}}
function renderPendingMenuFiles(){const h=$('#filehint'),box=$('#menuFileList');if(!h)return;const list=pendingMenuFiles();h.textContent=list.length?`已選擇 ${list.length} 個檔案，可個別移除後再儲存`:'可選，每個檔案上限 3.5MB';if(box)box.innerHTML=list.map((f,i)=>`<div class="small" style="display:flex;justify-content:space-between;gap:8px;margin-top:6px"><span>${esc(f.name)}</span><button class="btn light smallbtn" type="button" onclick="removeMenuFile(${i})">移除</button></div>`).join('')}
function removeMenuFile(i){const list=pendingMenuFiles();list.splice(i,1);$('#filehint').dataset.files=JSON.stringify(list);renderPendingMenuFiles()}
function importMenus(el){const files=[...el.files];if(!files.length)return;if(files.some(f=>f.size>3500000)){alert('每個檔案請勿超過 3.5MB');el.value='';return}Promise.all(files.map(f=>new Promise(resolve=>{const r=new FileReader();r.onload=()=>resolve({name:f.name,data:r.result});r.readAsDataURL(f)}))).then(list=>{$('#filehint').dataset.files=JSON.stringify([...pendingMenuFiles(),...list]);el.value='';renderPendingMenuFiles()})}
function createStore(){const name=$('#sname').value.trim(),mode=state.storeBuildMode||'full',raw=$('#sitems')?.value.trim()||'',items=mode==='full'?parseItems(raw):[];if(!name)return alert('請輸入店家名稱');if(mode==='full'&&!items.length)return alert('請輸入至少一個餐點');const id=$('#sname').dataset.id||crypto.randomUUID(),old=store(id)||{};let files=pendingMenuFiles();if(!files.length)files=old.menuFiles||(old.importData?[{name:old.importName||'菜單',data:old.importData}]:[]);if(mode==='quick'&&!files.length)return alert('請先上傳菜單檔案');const rec={...old,id,name,category:$('#scat').value.trim()||'',phone:$('#sphone').value.trim(),address:$('#saddress').value.trim(),method:'',note:$('#snote').value.trim(),items,quickMenu:mode==='quick',menuFiles:files,importName:files[0]?.name||'',importData:files[0]?.data||''};const i=data.stores.findIndex(s=>s.id===id);i<0?data.stores.push(rec):data.stores[i]=rec;save();state.storeQuery='';state.storeBuildMode='full';admin()}
function editStore(id){const s=store(id),files=s.menuFiles?.length?s.menuFiles:(s.importData?[{name:s.importName||'菜單',data:s.importData}]:[]);state.adminTab=1;state.storeQuery='';state.storeCategory='';state.storeBuildMode=s.quickMenu?'quick':'full';admin();$('#sname').value=s.name;$('#sname').dataset.id=s.id;$('#scat').value=s.category||'';$('#sphone').value=s.phone||'';$('#saddress').value=s.address||'';$('#snote').value=s.note||'';if($('#sitems'))$('#sitems').value=serializeBlockItems(s.items||[]);$('#filehint').dataset.files=JSON.stringify(files);renderPendingMenuFiles();setStoreBuildMode(state.storeBuildMode);window.scrollTo({top:0,behavior:'smooth'})}
const originalAdmin=admin;admin=function(){originalAdmin();const f=$('#view input[type="file"]');if(f){f.multiple=true;f.onchange=()=>importMenus(f);const label=f.previousElementSibling;if(label)label.textContent='原始菜單（可多選 PDF／JPG／PNG）';if(!$('#menuFileList'))f.insertAdjacentHTML('afterend','<div id="menuFileList"></div>');renderPendingMenuFiles()}};
function parseItems(text){if(!/【[^】]+】|品項\s*[:：]|規格\s*[:：]/.test(text))return parseLegacyItems(text);let section='',current=null,items=[];for(const raw of text.split(/\r?\n/)){const line=raw.trim();if(!line)continue;const header=line.match(/^【\s*(.*?)\s*】$/);if(header){section=header[1];current=null;continue}const item=line.match(/^品項\s*[:：]\s*(.*?)(?:\s*(?:=|\/|／)\s*(?:NT\$\s*)?(\d+(?:\.\d+)?))?$/i);if(item){current={name:item[1].trim(),section,price:Number(item[2]||0),specs:'單一規格',optionGroups:[]};if(!current.name)return[];items.push(current);continue}if(/^規格\s*[:：]?$/.test(line))continue;const group=line.match(/^-\s*\[\s*(.*?)\s*\]\s*[:：]\s*(.*)$/);if(group&&current){const values=[],adjustments={};for(const part of splitMulti(group[2])){const [label,rawPrice]=part.split('=').map(x=>x.trim());if(!label)return[];values.push(label);if(rawPrice!==undefined){const n=Number(rawPrice.replace(/^\+/,''));if(!Number.isFinite(n))return[];adjustments[label]=n}}const pricing=/價格/.test(group[1])&&values.some(v=>Object.prototype.hasOwnProperty.call(adjustments,v)&&!String(group[2]).includes(v+'=+'));if(pricing&&values.some(v=>!Object.prototype.hasOwnProperty.call(adjustments,v)))return[];current.optionGroups.push({name:group[1],values,adjustments,pricing});continue}return[]}return items}
function showMenuFile(id,index=0){const s=store(id),files=s.menuFiles?.length?s.menuFiles:(s.importData?[{name:s.importName||'菜單',data:s.importData}]:[]),file=files[index];if(!file)return;const content=file.data.startsWith('data:application/pdf')?`<object data="${file.data}" type="application/pdf" style="width:100%;height:65vh">無法預覽 PDF</object>`:`<img src="${file.data}" alt="${esc(file.name)}" style="width:100%;max-height:70vh;object-fit:contain">`,tabs=files.length>1?`<div class="tabs" style="padding:0 0 12px">${files.map((f,i)=>`<button class="tab ${i===index?'on':''}" onclick="showMenuFile('${s.id}',${i})">${esc(f.name)}</button>`).join('')}</div>`:'';$('#modal').innerHTML=`<div class="modal"><div class="modalbox" style="width:min(900px,100%)"><button class="btn light smallbtn" style="float:right" onclick="closeModal()">關閉</button><h2>${esc(s.name)}菜單</h2>${tabs}${content}</div></div>`}
let menuTouchX=null,menuPreviewState=null;
document.addEventListener('touchstart',e=>{if(menuPreviewState)menuTouchX=e.changedTouches[0].clientX},{passive:true});
document.addEventListener('touchend',e=>{if(menuTouchX===null||!menuPreviewState)return;const delta=e.changedTouches[0].clientX-menuTouchX,state=menuPreviewState;menuTouchX=null;if(Math.abs(delta)<45)return;const next=delta<0?state.index+1:state.index-1;if(next>=0&&next<state.total)showMenuFile(state.id,next)},{passive:true});
function showMenuFile(id,index=0){const s=store(id),files=s.menuFiles?.length?s.menuFiles:(s.importData?[{name:s.importName||'菜單',data:s.importData}]:[]),file=files[index];if(!file)return;menuPreviewState={id,index,total:files.length};const content=file.data.startsWith('data:application/pdf')?`<object data="${file.data}" type="application/pdf" style="width:100%;height:65vh">無法預覽 PDF</object>`:`<img src="${file.data}" alt="${esc(file.name)}" style="width:100%;max-height:70vh;object-fit:contain">`,tabs=files.length>1?`<div class="tabs" style="padding:0 0 12px">${files.map((f,i)=>`<button class="tab ${i===index?'on':''}" onclick="showMenuFile('${s.id}',${i})">${esc(f.name)}</button>`).join('')}</div><p class="hint">左右滑動可切換菜單</p>`:'';$('#modal').innerHTML=`<div class="modal"><div class="modalbox" style="width:min(900px,100%)"><button class="btn light smallbtn" style="float:right" onclick="closeModal()">關閉</button><h2>${esc(s.name)}菜單</h2>${tabs}${content}</div></div>`}
function mapHtml(address){if(!address)return '';const url='https://www.google.com/maps/search/?api=1&query='+encodeURIComponent(address);return `<div class="small" style="margin:8px 0">📍 ${esc(address)} <a href="${url}" target="_blank" rel="noopener" class="btn light smallbtn" style="display:inline-block;margin-left:4px;padding:4px 8px;text-decoration:none;vertical-align:middle">Google Maps →</a></div>`}
function parseItems(text){if(!/【[^】]+】|品項\s*[:：]|規格\s*[:：]/.test(text))return parseLegacyItems(text);let section='',current=null,items=[];for(const raw of text.split(/\r?\n/)){const line=raw.trim();if(!line)continue;const header=line.match(/^【\s*(.*?)\s*】$/);if(header){section=header[1];current=null;continue}if(/^品項\s*[:：]/.test(line)){const content=line.replace(/^品項\s*[:：]\s*/,'');const priced=content.match(/^(.*?)(?:\s*(?:=|\/|／)\s*(?:NT\$\s*)?(\d+(?:\.\d+)?))\s*$/i),name=(priced?priced[1]:content).trim();current={name,section,price:Number(priced?.[2]||0),specs:'單一規格',optionGroups:[]};if(!name)return[];items.push(current);continue}if(/^規格\s*[:：]?$/.test(line))continue;const group=line.match(/^-\s*\[\s*(.*?)\s*\]\s*[:：]\s*(.*)$/);if(group&&current){const values=[],adjustments={};for(const part of splitMulti(group[2])){const [label,rawPrice]=part.split('=').map(x=>x.trim());if(!label)return[];values.push(label);if(rawPrice!==undefined){const n=Number(rawPrice.replace(/^\+/,''));if(!Number.isFinite(n))return[];adjustments[label]=n}}const pricing=/價格/.test(group[1])&&values.some(v=>Object.prototype.hasOwnProperty.call(adjustments,v)&&!String(group[2]).includes(v+'=+'));if(pricing&&values.some(v=>!Object.prototype.hasOwnProperty.call(adjustments,v)))return[];current.optionGroups.push({name:group[1],values,adjustments,pricing});continue}return[]}return items}
const adminWithMenuPreview=admin;admin=function(){adminWithMenuPreview();$('#view').querySelectorAll('button[onclick^="previewStore("]').forEach(button=>{const match=button.getAttribute('onclick').match(/previewStore\('([^']+)'\)/),id=match?.[1],s=id&&store(id),files=s?.menuFiles?.length?s.menuFiles:(s?.importData?[{name:s.importName,data:s.importData}]:[]);if(!id||!files.length||button.parentElement.querySelector('[data-preview-menus]'))return;const preview=document.createElement('button');preview.className='btn light smallbtn';preview.dataset.previewMenus='1';preview.textContent='預覽全部菜單';preview.onclick=()=>showMenuFile(id);button.parentElement.insertBefore(preview,button.nextSibling)})};
const menuWithPhoneLink=menu;menu=function(){menuWithPhoneLink();const g=group(state.group),s=g&&store(g.storeId),phoneNode=$('#view .store-head .small');if(s?.phone&&phoneNode)phoneNode.innerHTML=`電話 <a href="tel:${esc(s.phone)}" style="color:inherit;text-decoration:underline">${esc(s.phone)}</a>`};
const menuWithLabels=menu;menu=function(){menuWithLabels();$('#view').querySelectorAll('button[onclick="go(\'home\')"]').forEach(button=>button.textContent='返回主頁');$('#view').querySelectorAll('button[onclick^="showMenuFile"]').forEach(button=>button.innerHTML='查看店家菜單 <span style="font-size:11px;font-weight:500">(供參考，實際以店家為主)</span>')};
function menu(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}$('#headline').textContent=s.name;const phone=s.phone?`電話 <a href="tel:${esc(s.phone)}" style="color:inherit;text-decoration:underline">${esc(s.phone)}</a>`:'';const files=s.menuFiles?.length?s.menuFiles:(s.importData?[{name:s.importName||'菜單',data:s.importData}]:[]);const menuButton=files.length?`<button class="btn light full" onclick="showMenuFile('${s.id}')">查看店家菜單 <span style="font-size:11px;font-weight:500">(供參考，實際以店家為主)</span></button>`:'';const header=`<button class="btn light" onclick="go('home')">返回主頁</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}</h2><div class="small">${phone}</div></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address)}${menuButton}`;if(s.quickMenu){$('#view').innerHTML=`${header}<div class="summary"><b>臨時菜單點餐</b><br>請查看店家菜單後，自行填寫訂購商品。</div><button class="btn full" onclick="startQuickOrder()">開始點餐</button></div>`;return}const namedSections=[...new Set(s.items.map(x=>x.section||'其他'))],sections=['全部商品',...namedSections];if(!sections.includes(state.menuSection))state.menuSection='全部商品';const listed=s.items.map((x,i)=>Object.assign({},x,{_menuIndex:i})).filter(x=>state.menuSection==='全部商品'||(x.section||'其他')===state.menuSection);const tabs=sections.length>2?`<div class="tabs" style="padding:0 0 12px">${sections.map(section=>`<button class="tab ${state.menuSection===section?'on':''}" data-section="${esc(section)}" onclick="setMenuSection(this.dataset.section)">${esc(section)}</button>`).join('')}</div>`:'';$('#view').innerHTML=`${header}<hr class="divider">${tabs}${sectionedMenuItems(listed)||'<p class="small">這間店尚未建立餐點。</p>'}</div>`}
function historyGroup(g){const s=store(g.storeId)||{},orders=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt)),phone=s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:'';return `<article class="card"><div class="group-title"><div><h3>${esc(s.name||'已刪除店家')}${phone}</h3><div class="group-meta">開團者：${esc(g.creator||'未填寫')}・${isOpen(g)?'收單 '+fmt(g.deadline):'已於 '+fmt(g.deadline)+' 結束'}</div></div><span class="pill ${isOpen(g)?'paid':'unpaid'}">${isOpen(g)?'本次團購':'過往團購'}</span></div>${orders.map(o=>`<div class="order"><b>${esc(o.buyer)}</b>${historyLines(o)}<div class="small">訂購時間：${fmt(o.createdAt)}</div></div>`).join('')||'<div class="empty">這次團購還沒有訂單</div>'}</article>`}
const menuWithPhoneBadge=menu;menu=function(){menuWithPhoneBadge();const g=group(state.group),s=g&&store(g.storeId),phoneNode=$('#view .store-head .small'),title=$('#view .store-head h2');if(s?.phone&&phoneNode&&title){title.insertAdjacentHTML('beforeend',` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`);phoneNode.remove()}};
function historySummary(orders){const rows=new Map();orders.forEach(o=>o.items.forEach(x=>{const key=`${x.name}\u0001${historySpec(x.spec)}`,row=rows.get(key)||{name:x.name,spec:historySpec(x.spec),qty:0};row.qty+=Number(x.qty)||0;rows.set(key,row)}));return [...rows.values()].map(x=>`${esc(x.name)}／${esc(x.spec)} × ${x.qty}`).join('<br>')||'尚無品項'}
function historyGroup(g){const s=store(g.storeId)||{},orders=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt)),phone=s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:'',total=orders.reduce((sum,o)=>sum+Number(o.total||0),0);return `<article class="card"><div class="group-title"><div><h3>${esc(s.name||'已刪除店家')}${phone}</h3><div class="group-meta">開團者：${esc(g.creator||'未填寫')}・${isOpen(g)?'收單 '+fmt(g.deadline):'已於 '+fmt(g.deadline)+' 結束'}</div></div><span class="pill ${isOpen(g)?'paid':'unpaid'}">${isOpen(g)?'本次團購':'過往團購'}</span></div>${orders.length?`<div class="summary"><b>品項數量加總</b><br>${historySummary(orders)}<br><br><b>訂單總金額：NT$ ${total.toLocaleString()}</b></div>`:''}${orders.map(o=>`<div class="order"><b>${esc(o.buyer)}</b>${historyLines(o)}<div class="small">訂購時間：${fmt(o.createdAt)}</div></div>`).join('')||'<div class="empty">這次團購還沒有訂單</div>'}</article>`}
function home(){const active=data.groups.filter(isOpen).sort((a,b)=>new Date(a.deadline)-new Date(b.deadline));$('#headline').textContent=active.length?`目前有 ${active.length} 個訂單進行中`:'目前沒有開放中的訂單';$('#view').innerHTML=active.length?active.map(g=>{const s=store(g.storeId)||{},phone=s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:'';return `<article class="card"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name||'已刪除店家')}${phone}</h2></div><b class="deadline open">開放中</b></div><div class="deadline">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div><button class="btn full" onclick="state.group='${g.id}';go('menu')">查看菜單／點餐</button></article>`}).join(''):`<div class="empty"><b>現在沒有開放中的訂單</b>管理者開團後，就可以在這裡開始點餐。</div>`}
function home(){const active=data.groups.filter(isOpen).sort((a,b)=>new Date(a.deadline)-new Date(b.deadline));$('#headline').textContent=active.length?`目前有 ${active.length} 個訂單進行中`:'目前沒有開放中的訂單';$('#view').innerHTML=active.length?active.map(g=>{const s=store(g.storeId)||{},phone=s.phone?`<div class="small" style="margin-top:5px"><a href="tel:${esc(s.phone)}" class="badge" style="text-decoration:none">☎ ${esc(s.phone)}</a></div>`:'';return `<article class="card"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><span class="deadline open" style="display:inline-block;margin:0 0 0 7px">收單 ${fmt(g.deadline)}</span><h2>${esc(s.name||'已刪除店家')}</h2>${phone}</div><b class="deadline open">開放中</b></div><div class="deadline">${g.payee?'💲付款者：'+esc(g.payee):''}</div><button class="btn full" onclick="state.group='${g.id}';go('menu')">查看菜單／點餐</button></article>`}).join(''):`<div class="empty"><b>現在沒有開放中的訂單</b>管理者開團後，就可以在這裡開始點餐。</div>`}
function mapHtml(address,phone=''){if(!address)return phone?`<div class="small" style="margin:8px 0">${phone}</div>`:'';const url='https://www.google.com/maps/search/?api=1&query='+encodeURIComponent(address),phoneBadge=phone?` <a href="tel:${esc(phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(phone)}</a>`:'';return `<div class="small" style="margin:8px 0">📍 ${esc(address)} <a href="${url}" target="_blank" rel="noopener" class="btn light smallbtn" style="display:inline-block;margin-left:4px;padding:4px 8px;text-decoration:none;vertical-align:middle">Google Maps →</a>${phoneBadge}</div>`}
function menu(){const g=group(state.group),s=g&&store(g.storeId);if(!g||!s)return go('home');if(!isOpen(g)){alert('這個團購已經結束');return go('home')}$('#headline').textContent=s.name;const files=s.menuFiles?.length?s.menuFiles:(s.importData?[{name:s.importName||'菜單',data:s.importData}]:[]),menuButton=files.length?` <button class="btn light smallbtn" style="vertical-align:middle;margin-left:6px" onclick="showMenuFile('${s.id}')">查看店家菜單 <span style="font-size:11px;font-weight:500">(供參考，實際以店家為主)</span></button>`:'';const header=`<button class="btn light" onclick="go('home')">返回主頁</button><div class="card" style="margin-top:14px"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><h2>${esc(s.name)}${menuButton}</h2></div><div class="deadline open">${g.payee?'💲付款者：'+esc(g.payee)+'・':''}收單 ${fmt(g.deadline)}</div></div>${s.note?`<p class="small">${esc(s.note)}</p>`:''}${mapHtml(s.address,s.phone)}`;if(s.quickMenu){$('#view').innerHTML=`${header}<div class="summary"><b>臨時菜單點餐</b><br>請查看店家菜單後，自行填寫訂購商品。</div><button class="btn full" onclick="startQuickOrder()">開始點餐</button></div>`;return}const namedSections=[...new Set(s.items.map(x=>x.section||'其他'))],sections=['全部商品',...namedSections];if(!sections.includes(state.menuSection))state.menuSection='全部商品';const listed=s.items.map((x,i)=>Object.assign({},x,{_menuIndex:i})).filter(x=>state.menuSection==='全部商品'||(x.section||'其他')===state.menuSection),tabs=sections.length>2?`<div class="tabs" style="padding:0 0 12px">${sections.map(section=>`<button class="tab ${state.menuSection===section?'on':''}" data-section="${esc(section)}" onclick="setMenuSection(this.dataset.section)">${esc(section)}</button>`).join('')}</div>`:'';$('#view').innerHTML=`${header}<hr class="divider">${tabs}${sectionedMenuItems(listed)||'<p class="small">這間店尚未建立餐點。</p>'}</div>`}
function deleteStore(id){const s=store(id);if(data.groups.some(g=>g.storeId===id))return alert('這間店已有開團紀錄，不能刪除');$('#modal').innerHTML=`<div class="modal"><div class="modalbox form"><h2>刪除店家</h2><p class="small">請輸入管理密碼，確認刪除「${esc(s?.name||'這間店')}」。</p><label>管理密碼</label><input id="deleteStorePassword" type="password" autocomplete="current-password" placeholder="請輸入密碼"><div class="row" style="margin-top:16px"><button class="btn light" onclick="closeModal()">取消</button><button class="btn danger" onclick="confirmStoreDelete('${id}')">確認刪除</button></div></div></div>`;setTimeout(()=>$('#deleteStorePassword')?.focus(),0)}
function confirmStoreDelete(id){if($('#deleteStorePassword').value!==data.password)return alert('密碼錯誤');data.stores=data.stores.filter(s=>s.id!==id);save();closeModal();admin()}
function adminGroupCard(g){const s=store(g.storeId)||{},os=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>{const ai=a.items[0]?.name||'',bi=b.items[0]?.name||'';return ai.localeCompare(bi,'zh-Hant')||new Date(a.createdAt)-new Date(b.createdAt)}),open=isOpen(g);return `<article class="card store-section"><div class="between"><div><h3>${esc(s.name||'已刪除店家')}${s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:''}</h3><div class="small">開團者：${esc(g.creator||'未填寫')}・${fmt(g.createdAt)}</div></div><div style="text-align:right"><button class="btn light smallbtn" onclick="openManualOrder('${g.id}')">＋ 新增訂單</button><div style="margin-top:7px"><span class="pill ${open?'paid':'unpaid'}">${open?'開團中':'已截止'}</span></div></div></div><div class="summary"><b>品項數量加總</b>${adminSummaryLines(os)}<br><b>訂單總金額：NT$ ${os.reduce((a,o)=>a+Number(o.total||0),0).toLocaleString()}</b></div>${os.map(o=>`<div class="order order-grid"><b>${esc(o.buyer)}</b><div class="details">${adminOrderLines(o)}</div><div class="adminlist"><button class="pill ${o.paid?'paid':'unpaid'}" onclick="togglePay('${o.id}')">${o.paid?'已付款':'未付款'}</button><button class="btn light smallbtn" onclick="removeOrder('${o.id}')">移除</button></div></div>`).join('')||'<p class="small">尚無訂單</p>'}</article>`}
function adminGroupCard(g){const s=store(g.storeId)||{},os=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>{const ai=a.items[0]?.name||'',bi=b.items[0]?.name||'';return ai.localeCompare(bi,'zh-Hant')||new Date(a.createdAt)-new Date(b.createdAt)}),open=isOpen(g);return `<article class="card store-section"><div class="between"><div><h3>${esc(s.name||'已刪除店家')}${s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:''}</h3><div class="small">開團者：${esc(g.creator||'未填寫')}・${fmt(g.createdAt)}</div></div><div style="text-align:right"><button class="btn light smallbtn" onclick="openManualOrder('${g.id}')">＋ 新增訂單</button><div style="margin-top:7px"><span class="pill ${open?'paid':'unpaid'}">開團狀態：${open?'開放中':'已結束'}</span></div></div></div><div class="summary"><b>品項數量加總</b>${adminSummaryLines(os)}<br><b>訂單總金額：NT$ ${os.reduce((a,o)=>a+Number(o.total||0),0).toLocaleString()}</b></div>${os.map(o=>`<div class="order order-grid"><b>${esc(o.buyer)}</b><div class="details">${adminOrderLines(o)}</div><div class="adminlist"><button class="pill ${o.paid?'paid':'unpaid'}" onclick="togglePay('${o.id}')">${o.paid?'已付款':'未付款'}</button><button class="btn light smallbtn" onclick="removeOrder('${o.id}')">移除</button></div></div>`).join('')||'<p class="small">尚無訂單</p>'}</article>`}
const statusLabelCard=adminGroupCard;adminGroupCard=function(g){return statusLabelCard(g).replace('開團狀態：開放中','開放中').replace('開團狀態：已結束','已結束')};
/* Final presentation refinements. */
function wantedHtml(orders){
  const people=[...new Set(orders.filter(o=>!o.paid).map(o=>o.buyer).filter(Boolean))]
    .sort(()=>Math.random()-.5).slice(0,2);
  return `<div class="wanted">🗿${people.length?' '+people.map(esc).join('、'):' 從缺'}</div>`;
}

function historyGroup(g){
  const s=store(g.storeId)||{},
    orders=data.orders.filter(o=>o.groupId===g.id).sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt)),
    phone=s.phone?` <a href="tel:${esc(s.phone)}" class="badge" style="vertical-align:middle;text-decoration:none">☎ ${esc(s.phone)}</a>`:'',
    total=orders.reduce((sum,o)=>sum+Number(o.total||0),0),
    status=isOpen(g)?'本次訂單':'過往訂單',
    ending=isOpen(g)?'收單 '+fmt(g.deadline):'已於 '+fmt(g.deadline)+' 結束';
  return `<article class="card"><div class="group-title"><div><h3>${esc(s.name||'已刪除店家')}${phone}</h3><div class="group-meta">開團者：${esc(g.creator||'未填寫')}・${ending}・${status}</div></div></div>${orders.length?`<div class="summary"><b>品項數量加總</b><br>${historySummary(orders)}<br><br><b>訂單總金額：NT$ ${total.toLocaleString()}</b></div>`:''}${orders.map(o=>`<div class="order"><b>${esc(o.buyer)}</b>${historyLines(o)}<div class="small">訂購時間：${fmt(o.createdAt)}</div></div>`).join('')||'<div class="empty">這次團購還沒有訂單</div>'}</article>`;
}

const menuWithStickyTabsAndReceipt=menu;
menu=function(){
  menuWithStickyTabsAndReceipt();
  const root=$('#view'),head=root.querySelector('.store-head'),category=head?.querySelector('div > .badge'),deadline=head?.querySelector(':scope > .deadline');
  if(category&&deadline){
    const receipt=document.createElement('span');
    receipt.className='badge';
    receipt.style.marginLeft='7px';
    receipt.textContent=deadline.textContent;
    category.insertAdjacentElement('afterend',receipt);
    deadline.remove();
  }
  root.querySelector('.tabs')?.classList.add('menu-tabs-sticky');
};

const adminWithStickyTabs=admin;
admin=function(){
  adminWithStickyTabs();
  $('#tabs').classList.add('admin-tabs-sticky');
};
function wantedHtml(orders){
  const people=[...new Set(orders.filter(o=>!o.paid).map(o=>o.buyer).filter(Boolean))]
    .sort(()=>Math.random()-.5).slice(0,2);
  return `<div class="wanted">${people.length?people.map(esc).join(' ')+' 🐔🔑🍌👛 🙏':'從缺'}</div>`;
}

function adminGroups(){
  const rows=[...data.groups].sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));
  return `<h2 class="section-title">開團管理</h2><div class="card form">
  <label>選擇店家${reqMark()}</label><select id="gstore">${data.stores.map(s=>`<option value="${s.id}">${esc(s.name)}（${esc(s.category||'未分類')}）</option>`).join('')||'<option value="">請先建立店家</option>'}</select>
  <label>開團者（選填）</label><input id="gcreator" maxlength="30" placeholder="可不填寫">
  <label>付款者（選填）</label><input id="gpayee" maxlength="30" placeholder="可不填寫">
  <label>想說的話（選填）</label><input id="gmessage" maxlength="120" placeholder="可不填寫">
  <label>收單時間${reqMark()}</label><input id="deadline" type="datetime-local">
  <button class="btn full" style="margin-top:14px" onclick="createGroup()">建立新團購</button></div>
  <div class="card"><b>開團紀錄</b>${rows.map(g=>`<div class="order"><b>${esc(store(g.storeId)?.name||'已刪除店家')}</b><span class="pill ${isOpen(g)?'paid':'unpaid'}" style="float:right">${isOpen(g)?'開放中':'已結束'}</span><div class="small">開團者：${esc(g.creator||'未填寫')}・付款者：${esc(g.payee||'未填寫')}・收單 ${fmt(g.deadline)}</div><div class="adminlist" style="margin-top:8px"><button class="btn light smallbtn" onclick="editGroup('${g.id}')">編輯</button>${isOpen(g)?`<button class="btn dark smallbtn" onclick="manualClose('${g.id}')">立即收單</button>`:''}<button class="btn danger smallbtn" onclick="deleteGroup('${g.id}')">刪除開團</button></div></div>`).join('')||'<p class="small">尚無開團紀錄</p>'}</div>`;
}

function createGroup(){
  if(!data.stores.length)return alert('請先建立店家');
  const d=$('#deadline').value,creator=$('#gcreator').value.trim(),payee=$('#gpayee').value.trim(),message=$('#gmessage').value.trim();
  if(!d)return alert('請選擇收單時間');
  const iso=new Date(d).toISOString();
  if(new Date(iso)<=now())return alert('收單時間必須晚於現在');
  data.groups.push({id:crypto.randomUUID(),storeId:$('#gstore').value,creator,payee,message,deadline:iso,createdAt:new Date().toISOString(),manualClosed:false});
  save();admin();
}

function editGroup(id){
  const g=group(id),d=new Date(g.deadline),v=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}T${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
  $('#modal').innerHTML=`<div class="modal"><div class="modalbox form"><h2>編輯團購</h2><label>開團者（選填）</label><input id="editCreator" value="${esc(g.creator||'')}"><label>付款者（選填）</label><input id="editPayee" value="${esc(g.payee||'')}"><label>想說的話（選填）</label><input id="editMessage" maxlength="120" value="${esc(g.message||'')}"><label>收單時間${reqMark()}</label><input id="editDeadline" type="datetime-local" value="${v}"><div class="row" style="margin-top:16px"><button class="btn light" onclick="closeModal()">取消</button><button class="btn" onclick="saveGroupEdit('${id}')">儲存並重新開放</button></div></div></div>`;
}

function saveGroupEdit(id){
  const g=group(id),creator=$('#editCreator').value.trim(),payee=$('#editPayee').value.trim(),message=$('#editMessage').value.trim(),d=$('#editDeadline').value;
  if(!d)return alert('請選擇收單時間');
  const iso=new Date(d).toISOString();
  if(new Date(iso)<=now())return alert('收單時間必須晚於現在');
  g.creator=creator;g.payee=payee;g.message=message;g.deadline=iso;g.manualClosed=false;save();closeModal();admin();
}

function home(){
  const active=data.groups.filter(isOpen).sort((a,b)=>new Date(a.deadline)-new Date(b.deadline));
  $('#headline').textContent=active.length?`目前有 ${active.length} 個訂單進行中`:'目前沒有開放中的訂單';
  $('#view').innerHTML=active.length?active.map(g=>{
    const s=store(g.storeId)||{},phone=s.phone?`<div class="small" style="margin-top:5px"><a href="tel:${esc(s.phone)}" class="badge" style="text-decoration:none">☎ ${esc(s.phone)}</a></div>`:'',message=g.message?`<div class="group-message">${esc(g.message)}</div>`:'';
    return `<article class="card"><div class="store-head"><div><span class="badge">${esc(s.category||'未分類')}</span><span class="deadline open" style="display:inline-block;margin:0 0 0 7px">收單 ${fmt(g.deadline)}</span><h2>${esc(s.name||'已刪除店家')}</h2>${phone}</div><b class="deadline open">開放中</b></div><div class="deadline">${g.payee?'💲付款者：'+esc(g.payee):''}</div><button class="btn full" onclick="state.group='${g.id}';go('menu')">查看菜單／點餐</button>${message}</article>`;
  }).join(''):`<div class="empty"><b>現在沒有開放中的訂單</b>管理者開團後，就可以在這裡開始點餐。</div>`;
}
const adminGroupsWithMultilineMessage=adminGroups;
adminGroups=function(){
  return adminGroupsWithMultilineMessage().replace(
    '<input id="gmessage" maxlength="120" placeholder="可不填寫">',
    '<textarea id="gmessage" class="group-message-input" maxlength="120" placeholder="可不填寫" style="min-height:78px"></textarea>'
  );
};

const editGroupWithMultilineMessage=editGroup;
editGroup=function(id){
  editGroupWithMultilineMessage(id);
  const input=$('#editMessage');
  if(!input)return;
  const area=document.createElement('textarea');
  area.id='editMessage';
  area.className='group-message-input';
  area.maxLength=120;
  area.style.minHeight='78px';
  area.value=input.value;
  input.replaceWith(area);
};
</script>
</body>
</html>
